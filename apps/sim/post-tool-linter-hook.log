boratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(201)\n    })\n\n    /**\n     * Test default permission level behavior\n     * Validates that unspecified permission levels default appropriately\n     */\n    it('should default to edit permission when not specified', async () => {\n      const collaboratorData = {\n        userId: 'default-user-777',\n        // permissionLevel omitted\n      }\n\n      const request = createMockRequest('POST', collaboratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(201)\n    })\n\n    /**\n     * Test comprehensive user information inclusion  \n     * Validates that collaborator responses include complete user profile data\n     */\n    it('should include user information in response', async () => {\n      const collaboratorData = {\n        userId: 'detailed-user-666',\n        permissionLevel: 'edit',\n      }\n\n      const request = createMockRequest('POST', collaboratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(201)\n      const data = await response.json()\n      expect(data.collaborator.userName).toBeDefined()\n      expect(data.collaborator.userEmail).toBeDefined()\n      expect(data.collaborator.addedByUserId).toBe(mockUser.id)\n    })\n  })\n\n  describe('Validation and Error Handling', () => {\n    /**\n     * Test authentication requirement for collaborator addition\n     * Validates that unauthenticated requests are properly rejected\n     */\n    it('should require authentication for adding collaborators', async () => {\n      // Setup unauthenticated session\n      const { getSession } = await import('@/lib/auth')\n      vi.mocked(getSession).mockResolvedValue(null)\n\n      const collaboratorData = { userId