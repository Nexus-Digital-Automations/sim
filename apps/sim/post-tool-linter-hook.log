tFolderId: 'folder-new-123',\n      }\n\n      const request = createEnhancedMockRequest('PATCH', bulkRequest)\n      const response = await PATCH(request)\n\n      expect(response.status).toBe(200)\n      \n      console.log('✅ Workspace permission checks successful')\n    })\n  }))\n})\n",
