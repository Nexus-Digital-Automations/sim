serId: 'test-user', permissionLevel: 'edit' }\n      const request = createMockRequest('POST', collaboratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(401)\n      const data = await response.json()\n      expect(data.error).toBe('Unauthorized')\n    })\n\n    /**\n     * Test edit permission requirement for adding collaborators\n     * Validates that only users with edit+ permissions can add collaborators\n     */\n    it('should require edit permissions to add collaborators', async () => {\n      // Setup user with insufficient permissions\n      const { getUserEntityPermissions } = await import('@/lib/permissions/utils')\n      vi.mocked(getUserEntityPermissions).mockResolvedValue('read')\n\n      const collaboratorData = { userId: 'test-user', permissionLevel: 'edit' }\n      const request = createMockRequest('POST', collaboratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(403)\n      const data = await response.json()\n      expect(data.error).toBe('Insufficient permissions')\n    })\n\n    /**\n     * Test request data validation  \n     * Validates proper schema validation for collaborator addition requests\n     */\n    it('should validate request data schema', async () => {\n      const invalidData = {\n        userId: '', // Empty user ID should fail validation\n        permissionLevel: 'invalid-permission',\n      }\n\n      const request = createMockRequest('POST', invalidData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(400)\n      const data = await response.json()\n      expect(data.error).toBe('Invalid request data')\n      expect(data.details).toBeDefined()\n    })\n\n    /**\n     * Test non-existent target user handling\n     * Validates proper 404 response when trying to add non-existent users\n     */\n    it('should return 404 for non-existent target user', async () => {\n      // Setup database to return empty user results\n      const { db } = await import('@/db')\n      vi.mocked(db.select).mockImplementation(() => ({\n        from: vi.fn().mockReturnThis(),\n        where: vi.fn().mockReturnThis(),\n        then: vi.fn().mockResolvedValue([]) // No user found\n      }) as any)\n\n      const collaboratorData = { userId: 'nonexistent-user', permissionLevel: 'edit' }\n      const request = createMockRequest('POST', collaboratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(404)\n      const data = await response.json()\n      expect(data.error).toBe('User not found')\n    })\n\n    /**\n     * Test duplicate collaborator prevention\n     * Validates that the same user cannot be added as a collaborator twice\n     */\n    it('should prevent duplicate collaborator addition', async () => {\n      // Setup database to return existing collaborator\n      const { db } = await import('@/db')\n      let selectCallCount = 0\n      vi.mocked(db.select).mockImplementation(() => ({\n        from: vi.fn().mockReturnThis(),\n        where: vi.fn().mockReturnThis(),\n        then: vi.fn().mockImplementation(() => {\n          selectCallCount++\n          if (selectCallCount === 1) {\n            // First call: workflow exists\n            return Promise.resolve([sampleWorkflowData])\n          } else if (selectCallCount === 2) {\n            // Second call: user exists\n            return Promise.resolve([sampleUserData])\n          } else {\n            // Third call: existing collaborator found\n            return Promise.resolve([sampleCollaboratorData])\n          }\n        })\n      }) as any)\n\n      const collaboratorData = { userId: 'existing-collaborator', permissionLevel: 'edit' }\n      const request = createMockRequest('POST', collaboratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(409)\n      const data = await response.json()\n      expect(data.error).toBe('User is already a collaborator')\n      expect(data.currentPermission).toBeDefined()\n    })\n\n    /**\n     * Test database insertion error handling\n     * Validates graceful handling of database write failures\n     */\n    it('should handle database insertion errors', async () => {\n      // Setup database insert error\n      const { db } = await import('@/db')\n      vi.mocked(db.insert).mockImplementation(() => {\n        throw new Error('Database insertion failed')\n      })\n\n      const collaboratorData = { userId: 'test-user', permissionLevel: 'edit' }\n      const request = createMockRequest('POST', collaboratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(500)\n      const data = await response.json()\n      expect(data.error).toBe('Internal server error')\n    })\n  })\n\n  describe('Permission Level Validation', () => {\n    /**\n     * Test valid permission levels acceptance\n     * Validates that all supported permission levels are accepted\n     */\n    it('should accept valid permission levels', async () => {\n      const validPermissions = ['view', 'edit', 'admin']\n      \n      for (const permission of validPermissions) {\n        const collaboratorData = { userId: `user-${permission}`, permissionLevel: permission }\n        const request = createMockRequest('POST', collaboratorData)\n        const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n        \n        expect(response.status).toBe(201)\n      }\n    })\n\n    /**\n     * Test invalid permission level rejection\n     * Validates that unsupported permission levels are properly rejected\n     */\n    it('should reject invalid permission levels', async () => {\n      const collaboratorData = { userId: 'test-user', permissionLevel: 'invalid-level' }\n      const request = createMockRequest('POST', collaboratorData)\n      const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(400)\n      const data = await response.json()\n      expect(data.error).toBe('Invalid request data')\n    })\n  })\n})\n\n// ================================\n// DELETE ENDPOINT TESTS\n// ================================\n\ndescribe('Collaborative Workflow API - DELETE /api/workflows/[id]/collaborate', () => {\n  \n  beforeEach(async () => {\n    // Clear all mocks to prevent test pollution\n    vi.clearAllMocks()\n    \n    // Import mocked services\n    const { getSession } = await import('@/lib/auth')\n    const { getUserEntityPermissions } = await import('@/lib/permissions/utils')\n    const { db } = await import('@/db')\n    \n    // Setup authenticated session\n    vi.mocked(getSession).mockResolvedValue({\n      user: { id: mockUser.id, email: mockUser.email, name: mockUser.name }\n    })\n    \n    // Setup admin permissions (required for removing collaborators)\n    vi.mocked(getUserEntityPermissions).mockResolvedValue('admin')\n    \n    // Setup database operations for collaborator removal\n    vi.mocked(db.select).mockImplementation(() => ({\n      from: vi.fn().mockReturnThis(),\n      where: vi.fn().mockReturnThis(),\n      then: vi.fn().mockResolvedValue([sampleCollaboratorData]) // Collaborator exists\n    }) as any)\n    \n    vi.mocked(db.delete).mockImplementation(() => ({\n      where: vi.fn().mockResolvedValue(undefined)\n    }) as any)\n  })\n\n  describe('Collaborator Removal', () => {\n    /**\n     * Test successful collaborator removal\n     * Validates complete workflow for removing existing collaborators\n     */\n    it('should remove a collaborator successfully', async () => {\n      const removeData = { userId: 'collaborator-to-remove' }\n\n      const request = createMockRequest('DELETE', removeData)\n      const response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(200)\n      const data = await response.json()\n      expect(data.success).toBe(true)\n      expect(data.message).toBe('Collaborator removed successfully')\n      expect(data.removedUserId).toBe('collaborator-to-remove')\n    })\n\n    /**\n     * Test collaboration session cleanup during removal\n     * Validates that active collaboration sessions are properly cleaned up\n     */\n    it('should clean up collaboration sessions when removing collaborator', async () => {\n      const removeData = { userId: 'active-collaborator' }\n\n      const request = createMockRequest('DELETE', removeData)\n      const response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(200)\n      \n      // Verify that db.delete was called twice (collaborator + sessions)\n      const { db } = await import('@/db')\n      expect(vi.mocked(db.delete)).toHaveBeenCalledTimes(2)\n    })\n  })\n\n  describe('Authentication and Authorization', () => {\n    /**\n     * Test authentication requirement for collaborator removal\n     * Validates that unauthenticated requests are properly rejected\n     */\n    it('should require authentication for removing collaborators', async () => {\n      // Setup unauthenticated session\n      const { getSession } = await import('@/lib/auth')\n      vi.mocked(getSession).mockResolvedValue(null)\n\n      const removeData = { userId: 'test-user' }\n      const request = createMockRequest('DELETE', removeData)\n      const response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(401)\n      const data = await response.json()\n      expect(data.error).toBe('Unauthorized')\n    })\n\n    /**\n     * Test admin permission requirement for collaborator removal\n     * Validates that only users with admin permissions can remove collaborators\n     */\n    it('should require admin permissions to remove collaborators', async () => {\n      // Setup user with insufficient permissions\n      const { getUserEntityPermissions } = await import('@/lib/permissions/utils')\n      vi.mocked(getUserEntityPermissions).mockResolvedValue('edit')\n\n      const removeData = { userId: 'test-user' }\n      const request = createMockRequest('DELETE', removeData)\n      const response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(403)\n      const data = await response.json()\n      expect(data.error).toBe('Insufficient permissions')\n    })\n\n    /**\n     * Test workflow owner removal privileges\n     * Validates that workflow owners can remove collaborators regardless of admin status\n     */\n    it('should allow workflow owner to remove collaborators', async () => {\n      // Set current user as workflow owner\n      const { getSession } = await import('@/lib/auth')\n      vi.mocked(getSession).mockResolvedValue({\n        user: { ...mockUser, id: 'owner-user-123' }\n      })\n\n      const removeData = { userId: 'collaborator-to-remove' }\n      const request = createMockRequest('DELETE', removeData)\n      const response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(200)\n    })\n  })\n\n  describe('Validation and Error Handling', () => {\n    /**\n     * Test request data validation for collaborator removal\n     * Validates proper schema validation for removal requests\n     */\n    it('should validate request data schema', async () => {\n      const invalidData = { userId: '' } // Empty user ID\n\n      const request = createMockRequest('DELETE', invalidData)\n      const response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(400)\n      const data = await response.json()\n      expect(data.error).toBe('Invalid request data')\n      expect(data.details).toBeDefined()\n    })\n\n    /**\n     * Test non-existent collaborator handling\n     * Validates proper 404 response when trying to remove non-existent collaborators\n     */\n    it('should return 404 for non-existent collaborator', async () => {\n      // Setup database to return empty collaborator results\n      const { db } = await import('@/db')\n      vi.mocked(db.select).mockImplementation(() => ({\n        from: vi.fn().mockReturnThis(),\n        where: vi.fn().mockReturnThis(),\n        then: vi.fn().mockResolvedValue([]) // No collaborator found\n      }) as any)\n\n      const removeData = { userId: 'nonexistent-collaborator' }\n      const request = createMockRequest('DELETE', removeData)\n      const response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(404)\n      const data = await response.json()\n      expect(data.error).toBe('Collaborator not found')\n    })\n\n    /**\n     * Test database deletion error handling\n     * Validates graceful handling of database delete failures\n     */\n    it('should handle database deletion errors', async () => {\n      // Setup database delete error\n      const { db } = await import('@/db')\n      vi.mocked(db.delete).mockImplementation(() => {\n        throw new Error('Database deletion failed')\n      })\n\n      const removeData = { userId: 'test-user' }\n      const request = createMockRequest('DELETE', removeData)\n      const response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(500)\n      const data = await response.json()\n      expect(data.error).toBe('Internal server error')\n    })\n  })\n})\n\n// ================================\n// COMPREHENSIVE SECURITY TESTS\n// ================================\n\ndescribe('Collaborative Workflow Permissions and Security', () => {\n  \n  beforeEach(async () => {\n    // Clear all mocks for security testing\n    vi.clearAllMocks()\n    \n    // Import mocked services\n    const { getSession } = await import('@/lib/auth')\n    const { getUserEntityPermissions } = await import('@/lib/permissions/utils')\n    const { db } = await import('@/db')\n    \n    // Setup base authentication\n    vi.mocked(getSession).mockResolvedValue({\n      user: { id: mockUser.id, email: mockUser.email, name: mockUser.name }\n    })\n    \n    // Setup base database mocking\n    vi.mocked(db.select).mockImplementation(() => ({\n      from: vi.fn().mockReturnThis(),\n      leftJoin: vi.fn().mockReturnThis(),\n      where: vi.fn().mockReturnThis(),\n      orderBy: vi.fn().mockReturnThis(),\n      then: vi.fn().mockResolvedValue([sampleWorkflowData])\n    }) as any)\n  })\n\n  describe('Permission Hierarchy', () => {\n    /**\n     * Test comprehensive permission hierarchy validation\n     * Validates that owner > admin > edit > view permission levels are properly enforced\n     */\n    it('should respect owner > admin > edit > view permission hierarchy', async () => {\n      const permissionTests = [\n        { role: 'owner', endpoint: 'GET', expectedStatus: 200 },\n        { role: 'admin', endpoint: 'GET', expectedStatus: 200 },\n        { role: 'edit', endpoint: 'GET', expectedStatus: 200 },\n        { role: 'view', endpoint: 'GET', expectedStatus: 200 },\n        { role: 'admin', endpoint: 'POST', expectedStatus: 201 },\n        { role: 'edit', endpoint: 'POST', expectedStatus: 201 },\n        { role: 'view', endpoint: 'POST', expectedStatus: 403 },\n        { role: 'owner', endpoint: 'DELETE', expectedStatus: 200 },\n        { role: 'admin', endpoint: 'DELETE', expectedStatus: 200 },\n        { role: 'edit', endpoint: 'DELETE', expectedStatus: 403 },\n      ]\n\n      for (const test of permissionTests) {\n        // Mock appropriate permissions for each test\n        if (test.role === 'owner') {\n          const { getSession } = await import('@/lib/auth')\n          vi.mocked(getSession).mockResolvedValue({\n            user: { ...mockUser, id: 'owner-user-123' }\n          })\n        } else {\n          const { getSession } = await import('@/lib/auth')\n          vi.mocked(getSession).mockResolvedValue({\n            user: mockUser\n          })\n          \n          const { getUserEntityPermissions } = await import('@/lib/permissions/utils')\n          vi.mocked(getUserEntityPermissions).mockResolvedValue(test.role)\n        }\n\n        let request: NextRequest\n        let response: Response\n        \n        switch (test.endpoint) {\n          case 'GET':\n            request = createMockRequest('GET')\n            response = await GET(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n            break\n          case 'POST':\n            request = createMockRequest('POST', { userId: 'test-user', permissionLevel: 'edit' })\n            response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n            break\n          case 'DELETE':\n            request = createMockRequest('DELETE', { userId: 'test-user' })\n            response = await DELETE(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n            break\n          default:\n            throw new Error(`Unsupported endpoint: ${test.endpoint}`)\n        }\n\n        expect(response.status).toBe(test.expectedStatus)\n      }\n    })\n  })\n\n  describe('Security Validation', () => {\n    /**\n     * Test unauthorized access prevention\n     * Validates that sensitive workflow data is protected from unauthorized access\n     */\n    it('should prevent unauthorized access to sensitive workflow data', async () => {\n      // Setup user without any permissions\n      const { getUserEntityPermissions } = await import('@/lib/permissions/utils')\n      vi.mocked(getUserEntityPermissions).mockResolvedValue(null)\n\n      const request = createMockRequest('GET')\n      const response = await GET(request, { params: Promise.resolve({ id: 'sensitive-workflow' }) })\n\n      expect(response.status).toBe(403)\n      const data = await response.json()\n      expect(data.error).toBe('Access denied')\n      \n      // Ensure no sensitive data leaked\n      expect(data.collaborators).toBeUndefined()\n      expect(data.workflowInfo).toBeUndefined()\n    })\n\n    /**\n     * Test input validation and injection attack prevention\n     * Validates that user input is properly sanitized and validated\n     */\n    it('should validate user input to prevent injection attacks', async () => {\n      const maliciousInputs = [\n        { userId: '<script>alert(\"xss\")</script>', permissionLevel: 'edit' },\n        { userId: 'test-user', permissionLevel: '\"; DROP TABLE users; --' },\n        { userId: '../../../etc/passwd', permissionLevel: 'edit' },\n      ]\n\n      for (const maliciousInput of maliciousInputs) {\n        const request = createMockRequest('POST', maliciousInput)\n        const response = await POST(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n        \n        // Should either reject with validation error or sanitize the input\n        expect([400, 404].includes(response.status)).toBe(true)\n      }\n    })\n\n    /**\n     * Test response data sanitization\n     * Validates that response data is properly sanitized before being returned\n     */\n    it('should sanitize response data', async () => {\n      const request = createMockRequest('GET')\n      const response = await GET(request, { params: Promise.resolve({ id: 'workflow-collab-123' }) })\n\n      expect(response.status).toBe(200)\n      const data = await response.json()\n      \n      // Validate that potentially sensitive fields are not exposed\n      expect(data.collaborators[0].password).toBeUndefined()\n      expect(data.collaborators[0].internalId).toBeUndefined()\n      expect(data.workflowInfo.internalMetadata).toBeUndefined()\n      \n      // Validate that proper fields are included\n      expect(data.collaborators[0].userName).toBeDefined()\n      expect(data.collaborators[0].userEmail).toBeDefined()\n      expect(data.collaborators[0].permissionLevel).toBeDefined()\n    })\n  })\n})",
