    "vm2": "^3.9.19"
  },
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/sim-ai/sim"
  },
  "bugs": {
    "url": "https://github.com/sim-ai/sim/issues"
  },
  "homepage": "https://sim.ai",
