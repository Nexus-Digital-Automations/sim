          "+      .change-type { font-weight: 600; text-transform: capitalize; }",
          "+      .entity-name { color: #586069; }",
          "+      .diff-dark .entity-name { color: #8b949e; }",
          "+      .change-badges { display: flex; gap: 4px; }",
