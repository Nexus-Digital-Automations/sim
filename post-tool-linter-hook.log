{section.items.map(renderDocumentationItem)}\n        </CollapsibleContent>\n      </Collapsible>\n    )\n  }\n\n  // ========================\n  // MAIN RENDER\n  // ========================\n\n  return (\n    <div className={cn('rounded-lg border bg-background', className)}>\n      <div className='border-b p-4'>\n        <div className='mb-3 flex items-center justify-between'>\n          <h1 className='font-semibold text-lg'>Documentation</h1>\n\n          {filterable && (\n            <DropdownMenu>\n              <DropdownMenuTrigger asChild>\n                <Button variant='outline' size='sm'>\n                  <FilterIcon className='mr-2 h-4 w-4' />\n                  Filter\n                </Button>\n              </DropdownMenuTrigger>\n              <DropdownMenuContent align='end' className='w-56'>\n                <div className='space-y-3 p-3'>\n                  <div>\n                    <label htmlFor='type-select' className='font-medium text-muted-foreground text-xs'>Type</label>\n                    <select\n                      id='type-select'\n                      value={selectedFilters.type || ''}\n                      onChange={(e) =>\n                        setSelectedFilters((prev) => ({\n                          ...prev,\n                          type: (e.target.value as DocumentationItem['type']) || undefined,\n                        }))\n                      }\n                      className='mt-1 w-full rounded border px-2 py-1 text-sm'\n                    >\n                      <option value=''>All types</option>\n                      {allTypes.map((type) => (\n                        <option key={type} value={type}>\n                          {type}\n                        </option>\n                      ))}\n                    </select>\n                  </div>\n\n                  <div>\n                    <label className='font-medium text-muted-foreground text-xs'>Difficulty</label>\n                    <select\