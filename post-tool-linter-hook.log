    "content": "---\ntitle: Rate Limits\ndescription: Understanding API rate limits and best practices for optimal performance\n---\n\nimport { Callout } from 'fumadocs-ui/components/callout'\n\n# Rate Limits\n\nThe Sim API implements rate limiting to ensure fair usage and optimal performance for all users. Rate limits vary based on your authentication method and subscription plan.\n\n## Current Limits\n\n### By Authentication Method\n\n| Authentication Type | Requests per minute | Requests per hour | Requests per day |\n|---------------------|--------------------|--------------------|------------------|\n| **API Key (Live)** | 1,000 | 10,000 | 100,000 |\n| **API Key (Test)** | 500 | 5,000 | 25,000 |\n| **Session Auth** | 500 | 5,000 | 25,000 |\n| **JWT Token** | 1,000 | 10,000 | 100,000 |\n\n### By Plan Type\n\n| Plan | Requests per minute | Requests per hour | Burst Limit |\n|------|--------------------|--------------------|-------------|\n| **Free** | 100 | 1,000 | 200 |\n| **Pro** | 1,000 | 10,000 | 2,000 |\n| **Team** | 2,000 | 20,000 | 5,000 |\n| **Enterprise** | Custom | Custom | Custom |\n\n## Rate Limit Headers\n\nEvery API response includes rate limit information in the headers:\n\n```http\nHTTP/1.1 200 OK\nX-RateLimit-Limit: 1000\nX-RateLimit-Remaining: 999\nX-RateLimit-Reset: 1640995200\nX-RateLimit-Window: 60\n```\n\n| Header | Description |\n|--------|-------------|\n| `X-RateLimit-Limit` | Maximum requests allowed in the current window |\n| `X-RateLimit-Remaining` | Requests remaining in the current window |\n| `X-RateLimit-Reset` | Unix timestamp when the window resets |\n| `X-RateLimit-Window` | Window duration in seconds |\n\n## Rate Limit Exceeded Response\n\nWhen you exceed the rate limit, you'll receive a `429 Too Many Requests` response:\n\n```json\n{\n  \"error\": \"Rate limit exceeded\",\n  \"message\": \"API rate limit exceeded. Try again in 45 seconds.\",\n  \"requestId\": \"req_abc123\",\n  \"retry_after\": 45,\n  \"limit\": 1000,\n  \"window\": 60\n}\n```\n\n## Best Practices\n\n### 1. Monitor Rate Limit Headers\n\nAlways check rate limit headers and implement logic to handle limits gracefully:\n\n```javascript\nasync function makeApiRequest(url, options = {}) {\n  const response = await fetch(url, options);\n  \n  // Check rate limit headers\n  const limit = response.headers.get('X-RateLimit-Limit');\n  const remaining = response.headers.get('X-RateLimit-Remaining');\n  const reset = response.headers.get('X-RateLimit-Reset');\n  \n  console.log(`Rate limit: ${remaining}/${limit}, resets at ${new Date(reset * 1000)}`);\n  \n  if (response.status === 429) {\n    const retryAfter = response.headers.get('Retry-After');\n    console.log(`Rate limited. Retry after ${retryAfter} seconds`);\n    throw new Error(`Rate limited. Retry after ${retryAfter} seconds`);\n  }\n  \n  return response;\n}\n```\n\n### 2. Implement Exponential Backoff\n\nWhen you hit rate limits, use exponential backoff for retries:\n\n```javascript\nasync function apiRequestWithBackoff(url, options = {}, maxRetries = 3) {\n  for (let attempt = 0; attempt <= maxRetries; attempt++) {\n    try {\n      const response = await fetch(url, options);\n      \n      if (response.status === 429) {\n        if (attempt === maxRetries) {\n          throw new Error('Max retries exceeded');\n        }\n        \n        const retryAfter = parseInt(response.headers.get('Retry-After') || '1');\n        const delay = Math.min(retryAfter * 1000, Math.pow(2, attempt) * 1000);\n        \n        console.log(`Rate limited. Waiting ${delay}ms before retry ${attempt + 1}`);\n        await new Promise(resolve => setTimeout(resolve, delay));\n        continue;\n      }\n      \n      return response;\n    } catch (error) {\n      if (attempt === maxRetries) throw error;\n      \n      const delay = Math.pow(2, attempt) * 1000;\n      console.log(`Request failed. Waiting ${delay}ms before retry ${attempt + 1}`);\n      await new Promise(resolve => setTimeout(resolve, delay));\n    }\n  }\n}\n```\n\n### 3. Batch Operations\n\nUse bulk endpoints when available to reduce the number of API calls:\n\n```javascript\n// Instead of multiple individual requests\nfor (const workflowId of workflowIds) {\n  await deleteWorkflow(workflowId);\n}\n\n// Use bulk operations\nawait bulkDeleteWorkflows(workflowIds);\n```\n\n### 4. Cache Frequently Used Data\n\nImplement caching to reduce API calls:\n\n```javascript\nclass WorkflowCache {\n  constructor(ttl = 300000) { // 5 minutes default\n    this.cache = new Map();\n    this.ttl = ttl;\n  }\n  \n  async getWorkflow(id) {\n    const cached = this.cache.get(id);\n    \n    if (cached && Date.now() - cached.timestamp < this.ttl) {\n      return cached.data;\n    }\n    \n    const workflow = await fetchWorkflowFromApi(id);\n    this.cache.set(id, {\n      data: workflow,\n      timestamp: Date.now()\n    });\n    \n    return workflow;\n  }\n}\n```\n\n### 5. Use Webhooks Instead of Polling\n\nFor real-time updates, use webhooks instead of frequently polling the API:\n\n```javascript\n// Bad: Frequent polling\nsetInterval(async () => {\n  const status = await checkWorkflowStatus(workflowId);\n  if (status === 'completed') {\n    handleCompletion();\n  }\n}, 5000); // This will quickly hit rate limits\n\n// Good: Use webhooks\napp.post('/webhook/workflow-completion', (req, res) => {\n  const { workflowId, status } = req.body;\n  if (status === 'completed') {\n    handleCompletion(workflowId);\n  }\n  res.status(200).send('OK');\n});\n```\n\n## Endpoint-Specific Limits\n\nSome endpoints have additional limits beyond the global rate limits:\n\n### Bulk Operations\n\n| Endpoint | Additional Limit |\n|----------|------------------|\n| `PATCH /api/workflows` (bulk) | Max 100 workflows per request |\n| `POST /api/workflows/[id]/export` (bulk) | Max 50 workflows per request |\n| `POST /api/workflows/validate` | Max 10 validations per minute |\n\n### Resource-Intensive Operations\n\n| Endpoint | Additional Limit |\n|----------|------------------|\n| `POST /api/workflows/yaml` | Max 5 MB YAML file |\n| `GET /api/workflows/[id]/export` | Max 1 export per minute per workflow |\n| `POST /api/workflows/[id]/execute` | Based on workflow complexity |\n\n## Monitoring Your Usage\n\n### Dashboard\n\nMonitor your API usage in the Sim dashboard:\n\n1. Go to Settings → API Usage\n2. View current rate limit status\n3. See usage analytics and trends\n4. Set up alerts for approaching limits\n\n### Programmatic Monitoring\n\nTrack your usage programmatically:\n\n```javascript\nclass RateLimitMonitor {\n  constructor() {\n    this.usage = {\n      requests: 0,\n      limit: 0,\n      remaining: 0,\n      resetTime: 0\n    };\n  }\n  \n  updateFromHeaders(headers) {\n    this.usage = {\n      requests: this.usage.requests + 1,\n      limit: parseInt(headers.get('X-RateLimit-Limit') || '0'),\n      remaining: parseInt(headers.get('X-RateLimit-Remaining') || '0'),\n      resetTime: parseInt(headers.get('X-RateLimit-Reset') || '0')\n    };\n  }\n  \n  getUsagePercent() {\n    return ((this.usage.limit - this.usage.remaining) / this.usage.limit) * 100;\n  }\n  \n  shouldWarn() {\n    return this.getUsagePercent() > 80; // Warn at 80% usage\n  }\n  \n  timeUntilReset() {\n    return Math.max(0, this.usage.resetTime - Math.floor(Date.now() / 1000));\n  }\n}\n```\n\n## Increasing Rate Limits\n\n### Upgrade Your Plan\n\nHigher-tier plans come with increased rate limits:\n\n- **Pro Plan**: 10x increase in rate limits\n- **Team Plan**: 20x increase with burst capacity\n- **Enterprise Plan**: Custom limits based on your needs\n\n### Request Limit Increase\n\nFor specific use cases, you can request temporary or permanent limit increases:\n\n1. Contact support at support@sim.dev\n2. Describe your use case and requirements\n3. Provide expected traffic patterns\n4. Include your current plan and account details\n\n<Callout type=\"info\">\n**Enterprise Customers**\nEnterprise customers can work with their account manager to set custom rate limits that match their specific needs and traffic patterns.\n</Callout>\n\n## Handling Different Scenarios\n\n### High-Volume Data Processing\n\nFor processing large amounts of data:\n\n```javascript\nclass BatchProcessor {\n  constructor(batchSize = 10, delayMs = 1000) {\n    this.batchSize = batchSize;\n    this.delayMs = delayMs;\n  }\n  \n  async processBatch(items, processor) {\n    const results = [];\n    \n    for (let i = 0; i < items.length; i += this.batchSize) {\n      const batch = items.slice(i, i + this.batchSize);\n      \n      const batchResults = await Promise.all(\n        batch.map(item => processor(item))\n      );\n      \n      results.push(...batchResults);\n      \n      // Delay between batches to stay within rate limits\n      if (i + this.batchSize < items.length) {\n        await new Promise(resolve => setTimeout(resolve, this.delayMs));\n      }\n    }\n    \n    return results;\n  }\n}\n```\n\n### Real-time Applications\n\nFor real-time applications that need frequent updates:\n\n```javascript\nclass RealTimeUpdater {\n  constructor(apiClient) {\n    this.apiClient = apiClient;\n    this.updateQueue = [];\n    this.isProcessing = false;\n  }\n  \n  queueUpdate(workflowId, changes) {\n    this.updateQueue.push({ workflowId, changes, timestamp: Date.now() });\n    this.processQueue();\n  }\n  \n  async processQueue() {\n    if (this.isProcessing) return;\n    this.isProcessing = true;\n    \n    while (this.updateQueue.length > 0) {\n      // Check rate limit before processing\n      const usage = await this.apiClient.getRateLimitStatus();\n      if (usage.remaining < 10) {\n        // Wait for rate limit reset if we're running low\n        await new Promise(resolve => \n          setTimeout(resolve, (usage.resetTime - Date.now()) + 1000)\n        );\n      }\n      \n      const update = this.updateQueue.shift();\n      try {\n        await this.apiClient.updateWorkflow(update.workflowId, update.changes);\n      } catch (error) {\n        if (error.status === 429) {\n          // Put the update back in the queue\n          this.updateQueue.unshift(update);\n          await new Promise(resolve => setTimeout(resolve, 5000));\n        }\n      }\n    }\n    \n    this.isProcessing = false;\n  }\n}\n```\n\n## Next Steps\n\n- [Error Codes](/docs/api/error-codes) - Handle API errors effectively\n- [Workflow Operations](/docs/api/workflows) - Start using the workflow API\n- [SDKs](/docs/api/sdks/javascript) - Use our client libraries with built-in rate limiting"
  },
