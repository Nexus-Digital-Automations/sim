id}/export        # Bulk export multiple workflows\n\nGET    /api/workflows/{id}/collaborate   # List collaborators\nPOST   /api/workflows/{id}/collaborate   # Add collaborator\nDELETE /api/workflows/{id}/collaborate   # Remove collaborator\n\nGET    /api/workflows/{id}/versions      # List workflow versions\nPOST   /api/workflows/{id}/versions      # Create new version\nGET    /api/workflows/{id}/versions/{v}  # Get specific version\n```\n\n## Quick Examples\n\n### List Workflows with Filtering\n\n<Tabs items={['cURL', 'JavaScript', 'Python']}>\n<Tab value=\"cURL\">\n```bash\ncurl -H \"x-api-key: YOUR_API_KEY\" \\\n  \"https://api.sim.dev/api/workflows?search=data&status=deployed&sortBy=updatedAt&limit=20\"\n```\n</Tab>\n<Tab value=\"JavaScript\">\n```javascript\nconst response = await fetch('/api/workflows?' + new URLSearchParams({\n  search: 'data processing',\n  status: 'deployed',\n  sortBy: 'updatedAt',\n  sortOrder: 'desc',\n  limit: '20'\n}), {\n  headers: {\n    'x-api-key': 'YOUR_API_KEY'\n  }\n});\n\nconst { data, pagination } = await response.json();\nconsole.log(`Found ${data.length} workflows out of ${pagination.total} total`);\n```\n</Tab>\n<Tab value=\"Python\">\n```python\nimport requests\n\nparams = {\n    'search': 'data processing',\n    'status': 'deployed', \n    'sortBy': 'updatedAt',\n    'sortOrder': 'desc',\n    'limit': 20\n}\n\nresponse = requests.get(\n    'https://api.sim.dev/api/workflows',\n    headers={'x-api-key': 'YOUR_API_KEY'},\n    params=params\n)\n\ndata = response.json()\nprint(f\"Found {len(data['data'])} workflows\")\n```\n</Tab>\n</Tabs>\n\n### Create Workflow\n\n<Tabs items={['cURL', 'JavaScript', 'Python']}>\n<Tab value=\"cURL\">\n```bash\ncurl -X POST \\\n  -H \"x-api-key: YOUR_API_KEY\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"name\": \"Data Processing Pipeline\",\n    \"description\": \"Automated data ingestion and transformation\",\n    \"color\": \"#3972F6\",\n    \"workspaceId\": \"ws_abc123\",\n    \"folderId\": \"folder_xyz789\"\n  }' \\\n  https://api.sim.dev/api/workflows\n```\n</Tab>\n<Tab value=\"JavaScript\">\n```javascript\nconst workflow = await fetch('/api/workflows', {\n  method: 'POST',\n  headers: {\n    'x-api-key': 'YOUR_API_KEY',\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({\n    name: 'Data Processing Pipeline',\n    description: 'Automated data ingestion and transformation',\n    color: '#3972F6',\n    workspaceId: 'ws_abc123',\n    folderId: 'folder_xyz789'\n  })\n});\n\nconst newWorkflow = await workflow.json();\nconsole.log('Created workflow:', newWorkflow.id);\n```\n</Tab>\n<Tab value=\"Python\">\n```python\nworkflow_data = {\n    'name': 'Data Processing Pipeline',\n    'description': 'Automated data ingestion and transformation',\n    'color': '#3972F6',\n    'workspaceId': 'ws_abc123',\n    'folderId': 'folder_xyz789'\n}\n\nresponse = requests.post(\n    'https://api.sim.dev/api/workflows',\n    headers={\n        'x-api-key': 'YOUR_API_KEY',\n        'Content-Type': 'application/json'\n    },\n    json=workflow_data\n)\n\nworkflow = response.json()\nprint(f\"Created workflow: {workflow['id']}\")\n```\n</Tab>\n</Tabs>\n\n### Import from YAML\n\n<Tabs items={['cURL', 'JavaScript', 'Python']}>\n<Tab value=\"cURL\">\n```bash\ncurl -X POST \\\n  -H \"x-api-key: YOUR_API_KEY\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"name\": \"Email Processing Workflow\",\n    \"description\": \"Process incoming emails and extract data\",\n    \"yaml\": \"version: \\\"1.0\\\"\\nblocks:\\n  - id: start\\n    metadata:\\n      id: starter\\n      name: Start\\n    position: { x: 100, y: 100 }\\n  - id: process_email\\n    metadata:\\n      id: gmail\\n      name: Read Email\\n    position: { x: 300, y: 100 }\\nconnections:\\n  - source: start\\n    target: process_email\"\n  }' \\\n  https://api.sim.dev/api/workflows/yaml\n```\n</Tab>\n<Tab value=\"JavaScript\">\n```javascript\nconst yamlWorkflow = `\nversion: \"1.0\"\nblocks:\n  - id: start\n    metadata:\n      id: starter\n      name: Start\n    position: { x: 100, y: 100 }\n  - id: process_email\n    metadata:\n      id: gmail\n      name: Read Email\n    position: { x: 300, y: 100 }\nconnections:\n  - source: start\n    target: process_email\n`;\n\nconst response = await fetch('/api/workflows/yaml', {\n  method: 'POST',\n  headers: {\n    'x-api-key': 'YOUR_API_KEY',\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({\n    name: 'Email Processing Workflow',\n    description: 'Process incoming emails and extract data',\n    yaml: yamlWorkflow\n  })\n});\n\nconst result = await response.json();\nconsole.log('Imported workflow:', result.id);\n```\n</Tab>\n<Tab value=\"Python\">\n```python\nyaml_content = \"\"\"\nversion: \"1.0\"\nblocks:\n  - id: start\n    metadata:\n      id: starter\n      name: Start\n    position: { x: 100, y: 100 }\n  - id: process_email\n    metadata:\n      id: gmail\n      name: Read Email\n    position: { x: 300, y: 100 }\nconnections:\n  - source: start\n    target: process_email\n\"\"\"\n\nresponse = requests.post(\n    'https://api.sim.dev/api/workflows/yaml',\n    headers={\n        'x-api-key': 'YOUR_API_KEY',\n        'Content-Type': 'application/json'\n    },\n    json={\n        'name': 'Email Processing Workflow',\n        'description': 'Process incoming emails and extract data',\n        'yaml': yaml_content\n    }\n)\n\nresult = response.json()\nprint(f\"Imported workflow: {result['id']}\")\n```\n</Tab>\n</Tabs>\n\n### Bulk Operations\n\n<Tabs items={['Delete Multiple', 'Move to Folder', 'Deploy Multiple']}>\n<Tab value=\"Delete Multiple\">\n```javascript\n// Delete multiple workflows at once\nconst response = await fetch('/api/workflows', {\n  method: 'PATCH',\n  headers: {\n    'x-api-key': 'YOUR_API_KEY',\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({\n    operation: 'delete',\n    workflowIds: ['wf_123', 'wf_456', 'wf_789']\n  })\n});\n\nconst result = await response.json();\nconsole.log(`Deleted ${result.results.length} workflows`);\n```\n</Tab>\n<Tab value=\"Move to Folder\">\n```javascript\n// Move workflows to a different folder\nconst response = await fetch('/api/workflows', {\n  method: 'PATCH',\n  headers: {\n    'x-api-key': 'YOUR_API_KEY',\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({\n    operation: 'move',\n    workflowIds: ['wf_123', 'wf_456'],\n    targetFolderId: 'folder_new'\n  })\n});\n```\n</Tab>\n<Tab value=\"Deploy Multiple\">\n```javascript\n// Deploy multiple workflows\nconst response = await fetch('/api/workflows', {\n  method: 'PATCH',\n  headers: {\n    'x-api-key': 'YOUR_API_KEY',\n    'Content-Type': 'application/json'\n  },\n  body: JSON.stringify({\n    operation: 'deploy',\n    workflowIds: ['wf_123', 'wf_456', 'wf_789']\n  })\n});\n\nconst result = await response.json();\nconsole.log('Deployment results:', result.results);\n```\n</Tab>\n</Tabs>\n\n## Common Workflow Object\n\nAll workflow operations return workflow objects with this structure:\n\n```json\n{\n  \"id\": \"wf_abc123\",\n  \"name\": \"Data Processing Pipeline\",\n  \"description\": \"Automated data ingestion and transformation\",\n  \"color\": \"#3972F6\",\n  \"userId\": \"user_123\",\n  \"workspaceId\": \"ws_abc123\", \n  \"folderId\": \"folder_xyz789\",\n  \"createdAt\": \"2024-01-15T10:00:00Z\",\n  \"updatedAt\": \"2024-01-16T14:30:00Z\",\n  \"isDeployed\": true,\n  \"deployedAt\": \"2024-01-16T12:00:00Z\",\n  \"runCount\": 47,\n  \"lastRunAt\": \"2024-01-16T14:25:00Z\",\n  \"isPublished\": false,\n  \"collaborators\": [\n    {\n      \"userId\": \"user_456\",\n      \"permissionLevel\": \"edit\",\n      \"addedAt\": \"2024-01-15T15:00:00Z\"\n    }\n  ],\n  \"state\": {\n    \"blocks\": {\n      \"start_1\": {\n        \"id\": \"start_1\",\n        \"type\": \"starter\",\n        \"name\": \"Start\",\n        \"position\": { \"x\": 100, \"y\": 100 },\n        \"config\