    "content": "---\ntitle: Troubleshooting\ndescription: Advanced troubleshooting techniques and common solutions for API integration issues\n---\n\nimport { Tabs, Tab } from 'fumadocs-ui/components/tabs'\nimport { Callout } from 'fumadocs-ui/components/callout'\n\n# API Troubleshooting\n\nThis guide provides advanced troubleshooting techniques for common API integration issues, debugging strategies, and best practices for maintaining reliable integrations with the Sim API.\n\n## Debugging Workflow\n\n### 1. Identify the Issue\n\nStart by gathering information about the problem:\n\n- **Error Messages**: Collect exact error messages and codes\n- **Request Details**: Log the full request (headers, body, URL)\n- **Response Details**: Capture complete response including headers\n- **Environment**: Note which environment (dev, staging, prod)\n- **Timing**: When did the issue start? Is it consistent?\n\n### 2. Reproduce the Issue\n\nCreate a minimal test case to reproduce the problem:\n\n<Tabs items={['Minimal Test', 'Curl Command', 'Debug Script']}>\n<Tab value=\"Minimal Test\">\n```javascript\n// Minimal test case to reproduce the issue\nasync function debugApiIssue() {\n  const testData = {\n    name: \"Debug Test Workflow\",\n    description: \"Minimal test case\"\n  };\n\n  console.log('Request data:', JSON.stringify(testData, null, 2));\n\n  try {\n    const response = await fetch('/api/workflows', {\n      method: 'POST',\n      headers: {\n        'x-api-key': 'YOUR_API_KEY',\n        'Content-Type': 'application/json'\n      },\n      body: JSON.stringify(testData)\n    });\n\n    console.log('Response status:', response.status);\n    console.log('Response headers:', Object.fromEntries(response.headers.entries()));\n\n    const result = await response.json();\n    console.log('Response body:', JSON.stringify(result, null, 2));\n\n    return result;\n  } catch (error) {\n    console.error('Request failed:', error);\n    throw error;\n  }\n}\n\n// Run the test\ndebugApiIssue().catch(console.error);\n```\n</Tab>\n<Tab value=\"Curl Command\">\n```bash\n# Generate a curl command for testing\ncurl -v -X POST \\\n  -H \"x-api-key: YOUR_API_KEY\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"name\": \"Debug Test Workflow\",\n    \"description\": \"Minimal test case\"\n  }' \\\n  https://api.sim.dev/api/workflows\n\n# The -v flag provides verbose output including:\n# - Request headers\n# - Response headers  \n# - Connection details\n# - SSL handshake info\n```\n</Tab>\n<Tab value=\"Debug Script\">\n```javascript\n// Comprehensive debug script\nclass APIDebugger {\n  constructor(apiKey, baseUrl = 'https://api.sim.dev') {\n    this.apiKey = apiKey;\n    this.baseUrl = baseUrl;\n  }\n\n  async debugRequest(method, endpoint, data = null) {\n    const url = `${this.baseUrl}${endpoint}`;\n    \n    console.log('=== API DEBUG SESSION START ===');\n    console.log(`Time: ${new Date().toISOString()}`);\n    console.log(`Method: ${method}`);\n    console.log(`URL: ${url}`);\n    \n    const options = {\n      method,\n      headers: {\n        'x-api-key': this.apiKey,\n        'Content-Type': 'application/json'\n      }\n    };\n\n    if (data) {\n      options.body = JSON.stringify(data);\n      console.log('Request Body:', JSON.stringify(data, null, 2));\n    }\n\n    console.log('Request Headers:', options.headers);\n\n    try {\n      const start = Date.now();\n      const response = await fetch(url, options);\n      const duration = Date.now() - start;\n\n      console.log(`\\nResponse (${duration}ms):`);\n      console.log(`Status: ${response.status} ${response.statusText}`);\n      console.log('Response Headers:', Object.fromEntries(response.headers.entries()));\n\n      let responseText;\n      try {\n        responseText = await response.text();\n        console.log('Response Body:', responseText);\n        \n        // Try to parse as JSON\n        const jsonData = JSON.parse(responseText);\n        return { success: response.ok, data: jsonData, status: response.status };\n      } catch (parseError) {\n        console.log('Response is not valid JSON');\n        return { success: response.ok, data: responseText, status: response.status };\n      }\n\n    } catch (error) {\n      console.error('\\nNetwork Error:', error);\n      return { success: false, error: error.message, status: 0 };\n    } finally {\n      console.log('=== API DEBUG SESSION END ===\\n');\n    }\n  }\n\n  async testConnectivity() {\n    console.log('Testing API connectivity...');\n    \n    // Test basic connectivity\n    try {\n      const response = await fetch(`${this.baseUrl}/api/workflows?limit=1`, {\n        headers: { 'x-api-key': this.apiKey }\n      });\n      \n      if (response.ok) {\n        console.log('✅ API connectivity: OK');\n        console.log('✅ Authentication: OK');\n      } else {\n        console.log('❌ API request failed:', response.status);\n        const error = await response.json();\n        console.log('Error details:', error);\n      }\n    } catch (error) {\n      console.log('❌ Network connectivity failed:', error.message);\n    }\n  }\n\n  async validateApiKey() {\n    console.log('Validating API key...');\n    \n    try {\n      const response = await fetch(`${this.baseUrl}/api/workflows?limit=1`, {\n        headers: { 'x-api-key': this.apiKey }\n      });\n      \n      if (response.status === 401) {\n        console.log('❌ API key is invalid or expired');\n        return false;\n      } else if (response.ok) {\n        console.log('✅ API key is valid');\n        return true;\n      } else {\n        console.log(`⚠️  API key valid but request failed: ${response.status}`);\n        return true; // Key is valid, other issue\n      }\n    } catch (error) {\n      console.log('❌ Could not validate API key:', error.message);\n      return false;\n    }\n  }\n}\n\n// Usage\nconst debugger = new APIDebugger('YOUR_API_KEY');\n\n// Test connectivity first\nawait debugger.testConnectivity();\nawait debugger.validateApiKey();\n\n// Debug specific request\nconst result = await debugger.debugRequest('POST', '/api/workflows', {\n  name: 'Debug Test',\n  description: 'Testing API'\n});\n```\n</Tab>\n</Tabs>\n\n## Common Issues and Solutions\n\n### Authentication Issues\n\n#### Problem: \"Invalid API Key\"\n\n<Tabs items={['Diagnosis', 'Solutions', 'Verification']}>\n<Tab value=\"Diagnosis\">\n```javascript\n// Diagnose API key issues\nasync function diagnoseApiKey(apiKey) {\n  console.log('Diagnosing API key issues...');\n  \n  // Check key format\n  if (!apiKey) {\n    console.error('❌ API key is missing');\n    return;\n  }\n  \n  if (!apiKey.startsWith('sk_')) {\n    console.error('❌ API key format invalid (should start with sk_)');\n    return;\n  }\n  \n  console.log('✅ API key format looks correct');\n  \n  // Test key validity\n  try {\n    const response = await fetch('https://api.sim.dev/api/workflows?limit=1', {\n      headers: { 'x-api-key': apiKey }\n    });\n    \n    switch (response.status) {\n      case 200:\n        console.log('✅ API key is valid and working');\n        break;\n      case 401:\n        const error = await response.json();\n        if (error.details?.type === 'invalid_api_key') {\n          console.error('❌ API key is invalid or has been revoked');\n        } else if (error.details?.type === 'expired_session') {\n          console.error('❌ API key has expired');\n        } else {\n          console.error('❌ Authentication failed:', error.message);\n        }\n        break;\n      case 403:\n        console.error('❌ API key valid but lacks permissions');\n        break;\n      default:\n        console.error(`❌ Unexpected response: ${response.status}`);\n    }\n  } catch (error) {\n    console.error('❌ Network error testing API key:', error.message);\n  }\n}\n\n// Usage\nawait diagnoseApiKey('sk_test_your_key_here');\n```\n</Tab>\n<Tab value=\"Solutions\">\n```javascript\n// Solutions for API key issues\nclass ApiKeyManager {\n  constructor() {\n    this.validationCache = new Map();\n    this.cacheTimeout = 5 * 60 * 1000; // 5 minutes\n  }\n\n  async getValidApiKey() {\n    // Try environment variables first\n    const envKey = process.env.SIM_API_KEY;\n    if (await this.validateKey(envKey)) {\n      return envKey;\n    }\n\n    // Try different environment variable names\n    const alternateKeys = [\n      process.env.SIM_API_TOKEN,\n      process.env.WORKFLOW_API_KEY,\n      process.env.API_KEY\n    ];\n\n    for (const key of alternateKeys) {\n      if (key && await this.validateKey(key)) {\n        console.log('✅ Found valid API key in alternate environment variable');\n        return key;\n      }\n    }\n\n    throw new Error('No valid API key found. Please check your environment variables.');\n  }\n\n  async validateKey(apiKey) {\n    if (!apiKey) return false;\n\n    // Check cache first\n    const cacheKey = apiKey.slice(-8); // Last 8 chars for cache key\n    const cached = this.validationCache.get(cacheKey);\n    if (cached && Date.now() - cached.timestamp < this.cacheTimeout) {\n      return cached.isValid;\n    }\n\n    try {\n      const response = await fetch('https://api.sim.dev/api/workflows?limit=1', {\n        headers: { 'x-api-key': apiKey }\n      });\n\n      const isValid = response.status !== 401;\n      \n      // Cache result\n      this.validationCache.set(cacheKey, {\n        isValid,\n        timestamp: Date.now()\n      });\n\n      return isValid;\n    } catch {\n      return false;\n    }\n  }\n\n  rotateApiKey() {\n    console.log(`\nTo rotate your API key:\n\n1. Go to https://sim.dev/settings/api-keys\n2. Create a new API key\n3. Update your environment variables:\n   export SIM_API_KEY=sk_live_new_key_here\n4. Test the new key\n5. Revoke the old key\n\nEnvironment setup:\n- Development: Use test keys (sk_test_...)\n- Production: Use live keys (sk_live_...)\n- Never commit keys to version control\n    `);\n  }\n}\n\n// Usage\nconst keyManager = new ApiKeyManager();\n\ntry {\n  const validKey = await keyManager.getValidApiKey();\n  console.log('✅ Using valid API key');\n} catch (error) {\n  console.error('❌ API key issue:', error.message);\n  keyManager.rotateApiKey();\n}\n```\n</Tab>\n<Tab value=\"Verification\">\n```bash\n#!/bin/bash\n# API key verification script\n\necho \"🔍 API Key Diagnostic Tool\"\necho \"==========================\"\n\n# Check if API key is set\nif [ -z \"$SIM_API_KEY\" ]; then\n    echo \"❌ SIM_API_KEY environment variable is not set\"\n    echo \"\"\n    echo \"To fix this:\"\n    echo \"export SIM_API_KEY=sk_your_key_here\"\n    exit 1\nfi\n\n# Check key format\nif [[ ! \"$SIM_API_KEY\" =~ ^sk_(test_|live_) ]]; then\n    echo \"❌ API key format is incorrect\"\n    echo \"Expected format: sk_test_... or sk_live_...\"\n    exit 1\nfi\n\necho \"✅ API key format is correct\"\n\n# Test key validity\necho \"🔍 Testing API key validity...\"\n\nresponse=$(curl -s -w \"HTTPSTATUS:%{http_code}\" \\\n    -H \"x-api-key: $SIM_API_KEY\" \\\n    \"https://api.sim.dev/api/workflows?limit=1\")\n\nhttp_code=$(echo \"$response\" | sed -n 's/.*HTTPSTATUS:\\([0-9]*\\)$/\\1/p')\nresponse_body=$(echo \"$response\" | sed 's/HTTPSTATUS:[0-9]*$//')\n\ncase $http_code in\n    200)\n        echo \"✅ API key is valid and working\"\n        # Show user info if available\n        user_info=$(echo \"$response_body\" | jq -r '.user // empty')\n        if [ ! -z \"$user_info\" ]; then\n            echo \"🔗 Connected as: $user_info\"\n        fi\n        ;;\n    401)\n        echo \"❌ API key is invalid or expired\"\n        echo \"Response: $response_body\"\n        exit 1\n        ;;\n    403)\n        echo \"❌ API key valid but lacks permissions\"\n        echo \"Response: $response_body\"\n        exit 1\n        ;;\n    *)\n        echo \"❌ Unexpected response: HTTP $http_code\"\n        echo \"Response: $response_body\"\n        exit 1\n        ;;\nesac\n\necho \"\"\necho \"✅ API key diagnostic completed successfully\"\n```\n</Tab>\n</Tabs>\n\n#### Problem: \"Session Expired\"\n\n```javascript\n// Handle session expiration\nclass SessionManager {\n  constructor(onSessionExpired) {\n    this.onSessionExpired = onSessionExpired;\n    this.isRefreshing = false;\n    this.failedQueue = [];\n  }\n\n  async handleRequest(requestFn) {\n    try {\n      return await requestFn();\n    } catch (error) {\n      if (error.status === 401 && error.details?.type === 'expired_session') {\n        return await this.handleSessionExpired(requestFn);\n      }\n      throw error;\n    }\n  }\n\n  async handleSessionExpired(requestFn) {\n    if (this.isRefreshing) {\n      // Queue the request while refreshing\n      return new Promise((resolve, reject) => {\n        this.failedQueue.push({ resolve, reject, requestFn });\n      });\n    }\n\n    this.isRefreshing = true;\n\n    try {\n      // Attempt to refresh session\n      await this.refreshSession();\n      \n      // Retry original request\n      const result = await requestFn();\n      \n      // Process queued requests\n      this.processQueue(null);\n      \n      return result;\n    } catch (refreshError) {\n      this.processQueue(refreshError);\n      \n      // Redirect to login or show auth modal\n      if (this.onSessionExpired) {\n        this.onSessionExpired();\n      }\n      \n      throw refreshError;\n    } finally {\n      this.isRefreshing = false;\n    }\n  }\n\n  async refreshSession() {\n    const response = await fetch('/api/auth/refresh', {\n      method: 'POST',\n      credentials: 'include'\n    });\n\n    if (!response.ok) {\n      throw new Error('Session refresh failed');\n    }\n  }\n\n  processQueue(error) {\n    this.failedQueue.forEach(({ resolve, reject, requestFn }) => {\n      if (error) {\n        reject(error);\n      } else {\n        resolve(requestFn());\n      }\n    });\n    \n    this.failedQueue = [];\n  }\n}\n\n// Usage\nconst sessionManager = new SessionManager(() => {\n  // Redirect to login\n  window.location.href = '/login';\n});\n\n// Wrap API calls\nasync function apiCall() {\n  return await sessionManager.handleRequest(async () => {\n    const response = await fetch('/api/workflows', {\n      credentials: 'include'\n    });\n    \n    if (!response.ok) {\n      const error = await response.json();\n      const apiError = new Error(error.message);\n      apiError.status = response.status;\n      apiError.details = error.details;\n      throw apiError;\n    }\n    \n    return await response.json();\n  });\n}\n```\n\n### Rate Limiting Issues\n\n#### Problem: \"Rate Limit Exceeded\"\n\n<Tabs items={['Detection', 'Handling', 'Prevention']}>\n<Tab value=\"Detection\">\n```javascript\n// Detect and analyze rate limiting\nclass RateLimitMonitor {\n  constructor() {\n    this.requestTimes = [];\n    this.rateLimitHits = [];\n  }\n\n  recordRequest() {\n    const now = Date.now();\n    this.requestTimes.push(now);\n    \n    // Keep only last hour of requests\n    const oneHour = 60 * 60 * 1000;\n    this.requestTimes = this.requestTimes.filter(time => now - time < oneHour);\n  }\n\n  recordRateLimit(retryAfter) {\n    this.rateLimitHits.push({\n      timestamp: Date.now(),\n      retryAfter\n    });\n  }\n\n  analyzeUsage() {\n    const now = Date.now();\n    const oneMinute = 60 * 1000;\n    const oneHour = 60 * 60 * 1000;\n\n    const requestsLastMinute = this.requestTimes.filter(time => \n      now - time < oneMinute\n    ).length;\n\n    const requestsLastHour = this.requestTimes.filter(time => \n      now - time < oneHour\n    ).length;\n\n    const recentRateLimits = this.rateLimitHits.filter(hit => \n      now - hit.timestamp < oneHour\n    ).length;\n\n    return {\n      requestsLastMinute,\n      requestsLastHour,\n      recentRateLimits,\n      avgRequestsPerMinute: requestsLastHour / 60,\n      isApproachingLimit: requestsLastMinute > 50 // Assuming 60/min limit\n    };\n  }\n\n  getRecommendations() {\n    const analysis = this.analyzeUsage();\n    const recommendations = [];\n\n    if (analysis.isApproachingLimit) {\n      recommendations.push('Slow down requests to avoid rate limiting');\n    }\n\n    if (analysis.recentRateLimits > 0) {\n      recommendations.push('Implement exponential backoff');\n      recommendations.push('Consider batching operations');\n    }\n\n    if (analysis.avgRequestsPerMinute > 30) {\n      recommendations.push('Consider upgrading your plan for higher limits');\n    }\n\n    return recommendations;\n  }\n}\n\n// Usage\nconst monitor = new RateLimitMonitor();\n\nasync function monitoredRequest(url, options) {\n  monitor.recordRequest();\n  \n  try {\n    const response = await fetch(url, options);\n    \n    // Check rate limit headers\n    const remaining = parseInt(response.headers.get('x-ratelimit-remaining') || '0');\n    const limit = parseInt(response.headers.get('x-ratelimit-limit') || '0');\n    \n    if (remaining < limit * 0.1) { // Less than 10% remaining\n      console.warn(`⚠️ Rate limit warning: ${remaining}/${limit} remaining`);\n    }\n    \n    if (response.status === 429) {\n      const retryAfter = parseInt(response.headers.get('retry-after') || '60');\n      monitor.recordRateLimit(retryAfter);\n      throw new Error(`Rate limited. Retry after ${retryAfter}s`);\n    }\n    \n    return response;\n  } catch (error) {\n    const analysis = monitor.analyzeUsage();\n    const recommendations = monitor.getRecommendations();\n    \n    if (recommendations.length > 0) {\n      console.warn('Rate limit recommendations:', recommendations);\n    }\n    \n    throw error;\n  }\n}\n```\n</Tab>\n<Tab value=\"Handling\">\n```javascript\n// Robust rate limit handling\nclass RateLimitHandler {\n  constructor(options = {}) {\n    this.baseDelay = options.baseDelay || 1000;\n    this.maxDelay = options.maxDelay || 60000;\n    this.maxRetries = options.maxRetries || 5;\n    this.jitterFactor = options.jitterFactor || 0.1;\n  }\n\n  async withRateLimit(requestFn, options = {}) {\n    let lastError;\n    \n    for (let attempt = 0; attempt < this.maxRetries; attempt++) {\n      try {\n        return await requestFn();\n      } catch (error) {\n        lastError = error;\n        \n        // Only retry on rate limit errors\n        if (error.status !== 429) {\n          throw error;\n        }\n        \n        if (attempt === this.maxRetries - 1) {\n          throw new Error(`Rate limit retries exhausted. Last error: ${error.message}`);\n        }\n        \n        const delay = this.calculateDelay(attempt, error);\n        console.log(`Rate limited. Waiting ${delay}ms before retry ${attempt + 1}...`);\n        \n        await this.sleep(delay);\n      }\n    }\n    \n    throw lastError;\n  }\n\n  calculateDelay(attempt, error) {\n    // Use server-provided retry-after if available\n    if (error.retryAfter) {\n      return Math.min(error.retryAfter * 1000, this.maxDelay);\n    }\n    \n    // Exponential backoff with jitter\n    const exponentialDelay = this.baseDelay * Math.pow(2, attempt);\n    const jitter = exponentialDelay * this.jitterFactor * Math.random();\n    \n    return Math.min(exponentialDelay + jitter, this.maxDelay);\n  }\n\n  sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n}\n\n// Request queue to prevent overwhelming the API\nclass RequestQueue {\n  constructor(concurrency = 5, delayBetweenRequests = 200) {\n    this.concurrency = concurrency;\n    this.delay = delayBetweenRequests;\n    this.queue = [];\n    this.running = 0;\n    this.rateLimitHandler = new RateLimitHandler();\n  }\n\n  async add(requestFn) {\n    return new Promise((resolve, reject) => {\n      this.queue.push({\n        requestFn,\n        resolve,\n        reject\n      });\n      \n      this.process();\n    });\n  }\n\n  async process() {\n    if (this.running >= this.concurrency || this.queue.length === 0) {\n      return;\n    }\n\n    this.running++;\n    const { requestFn, resolve, reject } = this.queue.shift();\n\n    try {\n      const result = await this.rateLimitHandler.withRateLimit(requestFn);\n      resolve(result);\n    } catch (error) {\n      reject(error);\n    } finally {\n      this.running--;\n      \n      // Add delay between requests\n      if (this.queue.length > 0) {\n        setTimeout(() => this.process(), this.delay);\n      }\n    }\n  }\n}\n\n// Usage\nconst requestQueue = new RequestQueue(3, 500); // 3 concurrent, 500ms between\n\n// Queue requests to avoid rate limiting\nasync function createWorkflows(workflowsData) {\n  const results = [];\n  \n  for (const workflowData of workflowsData) {\n    const result = await requestQueue.add(async () => {\n      const response = await fetch('/api/workflows', {\n        method: 'POST',\n        headers: {\n          'x-api-key': 'YOUR_API_KEY',\n          'Content-Type': 'application/json'\n        },\n        body: JSON.stringify(workflowData)\n      });\n\n      if (!response.ok) {\n        const error = await response.json();\n        const apiError = new Error(error.message);\n        apiError.status = response.status;\n        apiError.retryAfter = error.details?.retry_after;\n        throw apiError;\n      }\n\n      return await response.json();\n    });\n    \n    results.push(result);\n  }\n  \n  return results;\n}\n```\n</Tab>\n<Tab value=\"Prevention\">\n```javascript\n// Prevent rate limiting through intelligent request management\nclass IntelligentApiClient {\n  constructor(apiKey) {\n    this.apiKey = apiKey;\n    this.requestStats = {\n      count: 0,\n      lastReset: Date.now(),\n      windowSize: 60000 // 1 minute\n    };\n    this.adaptiveDelay = 100; // Start with 100ms delay\n    this.maxDelay = 2000; // Max 2s delay\n  }\n\n  async request(endpoint, options = {}) {\n    // Check if we should slow down\n    await this.adaptiveThrottle();\n    \n    try {\n      const response = await fetch(endpoint, {\n        ...options,\n        headers: {\n          'x-api-key': this.apiKey,\n          ...options.headers\n        }\n      });\n\n      this.updateStats(response);\n      \n      if (!response.ok) {\n        throw new Error(`HTTP ${response.status}: ${response.statusText}`);\n      }\n      \n      return await response.json();\n    } catch (error) {\n      this.handleError(error);\n      throw error;\n    }\n  }\n\n  async adaptiveThrottle() {\n    // Reset stats if window expired\n    const now = Date.now();\n    if (now - this.requestStats.lastReset > this.requestStats.windowSize) {\n      this.requestStats.count = 0;\n      this.requestStats.lastReset = now;\n    }\n\n    // Increase delay if making too many requests\n    const requestsPerMinute = this.requestStats.count;\n    if (requestsPerMinute > 50) {\n      this.adaptiveDelay = Math.min(this.adaptiveDelay * 1.5, this.maxDelay);\n    } else if (requestsPerMinute < 20) {\n      this.adaptiveDelay = Math.max(this.adaptiveDelay * 0.9, 100);\n    }\n\n    if (this.adaptiveDelay > 100) {\n      await new Promise(resolve => setTimeout(resolve, this.adaptiveDelay));\n    }\n  }\n\n  updateStats(response) {\n    this.requestStats.count++;\n\n    // Adjust delay based on rate limit headers\n    const remaining = parseInt(response.headers.get('x-ratelimit-remaining') || '1000');\n    const limit = parseInt(response.headers.get('x-ratelimit-limit') || '1000');\n    const resetTime = parseInt(response.headers.get('x-ratelimit-reset') || '0');\n\n    // If we're using too much quota, slow down\n    const usagePercentage = ((limit - remaining) / limit) * 100;\n    \n    if (usagePercentage > 80) {\n      this.adaptiveDelay = Math.min(this.adaptiveDelay * 2, this.maxDelay);\n    } else if (usagePercentage < 50) {\n      this.adaptiveDelay = Math.max(this.adaptiveDelay * 0.8, 100);\n    }\n  }\n\n  handleError(error) {\n    if (error.message.includes('429')) {\n      // Significantly increase delay after rate limiting\n      this.adaptiveDelay = Math.min(this.adaptiveDelay * 3, this.maxDelay);\n    }\n  }\n\n  // Batch operations to reduce API calls\n  async batchOperation(operation, items, batchSize = 10) {\n    const results = [];\n    \n    for (let i = 0; i < items.length; i += batchSize) {\n      const batch = items.slice(i, i + batchSize);\n      console.log(`Processing batch ${Math.floor(i / batchSize) + 1}/${Math.ceil(items.length / batchSize)}`);\n      \n      const batchResults = await Promise.all(\n        batch.map(item => operation(item))\n      );\n      \n      results.push(...batchResults);\n      \n      // Add delay between batches\n      if (i + batchSize < items.length) {\n        await new Promise(resolve => setTimeout(resolve, this.adaptiveDelay));\n      }\n    }\n    \n    return results;\n  }\n}\n\n// Usage\nconst apiClient = new IntelligentApiClient('YOUR_API_KEY');\n\n// The client automatically manages rate limits\nconst workflows = await apiClient.request('/api/workflows');\n\n// Batch operations with automatic throttling  \nconst results = await apiClient.batchOperation(\n  async (workflowData) => apiClient.request('/api/workflows', {\n    method: 'POST',\n    body: JSON.stringify(workflowData)\n  }),\n  workflowsToCreate,\n  5 // Process 5 at a time\n);\n```\n</Tab>\n</Tabs>\n\n### Network and Connectivity Issues\n\n#### Problem: Network Timeouts\n\n```javascript\n// Handle network issues robustly\nclass NetworkHandler {\n  constructor(options = {}) {\n    this.timeout = options.timeout || 30000; // 30s default\n    this.retryDelays = options.retryDelays || [1000, 2000, 5000];\n    this.retryableErrors = [\n      'NETWORK_ERROR',\n      'TIMEOUT',\n      'CONNECTION_RESET',\n      'DNS_ERROR'\n    ];\n  }\n\n  async fetchWithRetry(url, options = {}) {\n    const controller = new AbortController();\n    const timeoutId = setTimeout(() => controller.abort(), this.timeout);\n\n    let lastError;\n    \n    for (let attempt = 0; attempt < this.retryDelays.length + 1; attempt++) {\n      try {\n        const response = await fetch(url, {\n          ...options,\n          signal: controller.signal\n        });\n\n        clearTimeout(timeoutId);\n        return response;\n\n      } catch (error) {\n        lastError = error;\n        \n        const errorType = this.classifyError(error);\n        console.log(`Attempt ${attempt + 1} failed: ${errorType}`);\n\n        // Don't retry non-network errors\n        if (!this.retryableErrors.includes(errorType)) {\n          break;\n        }\n\n        // Don't retry on last attempt\n        if (attempt === this.retryDelays.length) {\n          break;\n        }\n\n        // Wait before retry\n        const delay = this.retryDelays[attempt];\n        console.log(`Retrying in ${delay}ms...`);\n        await new Promise(resolve => setTimeout(resolve, delay));\n      }\n    }\n\n    clearTimeout(timeoutId);\n    throw new Error(`Network request failed after ${this.retryDelays.length + 1} attempts: ${lastError.message}`);\n  }\n\n  classifyError(error) {\n    if (error.name === 'AbortError') {\n      return 'TIMEOUT';\n    }\n    \n    if (error.message.includes('Failed to fetch')) {\n      return 'NETWORK_ERROR';\n    }\n    \n    if (error.message.includes('ERR_NETWORK_CHANGED')) {\n      return 'NETWORK_ERROR';\n    }\n    \n    if (error.message.includes('ERR_INTERNET_DISCONNECTED')) {\n      return 'NETWORK_ERROR';\n    }\n    \n    return 'UNKNOWN_ERROR';\n  }\n\n  async checkConnectivity() {\n    const tests = [\n      { name: 'DNS Resolution', test: () => fetch('https://1.1.1.1', { mode: 'no-cors' }) },\n      { name: 'Internet Connectivity', test: () => fetch('https://httpbin.org/get', { mode: 'cors' }) },\n      { name: 'Sim API Reachability', test: () => fetch('https://api.sim.dev/health', { mode: 'cors' }) }\n    ];\n\n    const results = [];\n\n    for (const { name, test } of tests) {\n      try {\n        const start = Date.now();\n        await test();\n        const duration = Date.now() - start;\n        results.push({ name, status: 'OK', duration });\n        console.log(`✅ ${name}: OK (${duration}ms)`);\n      } catch (error) {\n        results.push({ name, status: 'FAILED', error: error.message });\n        console.log(`❌ ${name}: FAILED - ${error.message}`);\n      }\n    }\n\n    return results;\n  }\n}\n\n// Usage\nconst networkHandler = new NetworkHandler({\n  timeout: 15000,\n  retryDelays: [1000, 3000, 5000]\n});\n\nasync function robustApiCall(endpoint, options) {\n  try {\n    // Check connectivity first if previous requests failed\n    const connectivity = await networkHandler.checkConnectivity();\n    const hasConnectivity = connectivity.every(test => test.status === 'OK');\n    \n    if (!hasConnectivity) {\n      throw new Error('Network connectivity issues detected');\n    }\n\n    const response = await networkHandler.fetchWithRetry(endpoint, options);\n    return await response.json();\n  } catch (error) {\n    console.error('Robust API call failed:', error.message);\n    throw error;\n  }\n}\n```\n\n## Performance Debugging\n\n### Slow API Responses\n\n<Tabs items={['Performance Monitoring', 'Request Optimization', 'Caching Strategy']}>\n<Tab value=\"Performance Monitoring\">\n```javascript\n// Monitor API performance\nclass PerformanceMonitor {\n  constructor() {\n    this.metrics = new Map();\n  }\n\n  startTimer(requestId) {\n    return {\n      start: performance.now(),\n      requestId,\n      checkpoints: []\n    };\n  }\n\n  checkpoint(timer, name) {\n    timer.checkpoints.push({\n      name,\n      time: performance.now() - timer.start\n    });\n  }\n\n  endTimer(timer) {\n    const total = performance.now() - timer.start;\n    \n    const metric = {\n      requestId: timer.requestId,\n      totalTime: total,\n      checkpoints: timer.checkpoints\n    };\n\n    this.metrics.set(timer.requestId, metric);\n    return metric;\n  }\n\n  async monitorRequest(requestFn, requestId = `req_${Date.now()}`) {\n    const timer = this.startTimer(requestId);\n\n    try {\n      this.checkpoint(timer, 'request_start');\n      \n      const result = await requestFn();\n      \n      this.checkpoint(timer, 'response_received');\n      \n      const metrics = this.endTimer(timer);\n      this.analyzePerformance(metrics);\n      \n      return result;\n    } catch (error) {\n      this.checkpoint(timer, 'error_occurred');\n      const metrics = this.endTimer(timer);\n      \n      console.error(`Request ${requestId} failed after ${metrics.totalTime.toFixed(2)}ms:`, error.message);\n      throw error;\n    }\n  }\n\n  analyzePerformance(metrics) {\n    const { requestId, totalTime, checkpoints } = metrics;\n    \n    console.log(`📊 Request ${requestId} Performance:`);\n    console.log(`   Total Time: ${totalTime.toFixed(2)}ms`);\n    \n    checkpoints.forEach((checkpoint, index) => {\n      const previousTime = index > 0 ? checkpoints[index - 1].time : 0;\n      const duration = checkpoint.time - previousTime;\n      console.log(`   ${checkpoint.name}: ${duration.toFixed(2)}ms`);\n    });\n\n    // Performance warnings\n    if (totalTime > 5000) {\n      console.warn(`⚠️  Slow request detected: ${totalTime.toFixed(2)}ms`);\n    }\n\n    if (totalTime > 10000) {\n      console.error(`🚨 Very slow request: ${totalTime.toFixed(2)}ms`);\n      this.suggestOptimizations();\n    }\n  }\n\n  suggestOptimizations() {\n    console.log(`\n💡 Performance Optimization Suggestions:\n   - Use pagination to reduce response size\n   - Add specific field filters to reduce payload\n   - Implement client-side caching\n   - Consider using bulk operations\n   - Check network connectivity and latency\n    `);\n  }\n\n  getAveragePerformance() {\n    const metrics = Array.from(this.metrics.values());\n    if (metrics.length === 0) return null;\n\n    const avgTime = metrics.reduce((sum, m) => sum + m.totalTime, 0) / metrics.length;\n    const slowRequests = metrics.filter(m => m.totalTime > 5000).length;\n\n    return {\n      averageTime: avgTime,\n      totalRequests: metrics.length,\n      slowRequests,\n      slowRequestPercentage: (slowRequests / metrics.length) * 100\n    };\n  }\n}\n\n// Usage\nconst perfMonitor = new PerformanceMonitor();\n\nasync function monitoredApiCall() {\n  return await perfMonitor.monitorRequest(async () => {\n    const response = await fetch('/api/workflows', {\n      headers: { 'x-api-key': 'YOUR_API_KEY' }\n    });\n    return await response.json();\n  });\n}\n\n// Monitor multiple requests\nconst results = await Promise.all([\n  monitoredApiCall(),\n  monitoredApiCall(),\n  monitoredApiCall()\n]);\n\n// Get performance summary\nconst summary = perfMonitor.getAveragePerformance();\nconsole.log('Performance Summary:', summary);\n```\n</Tab>\n<Tab value=\"Request Optimization\">\n```javascript\n// Optimize API requests for better performance\nclass RequestOptimizer {\n  constructor(apiKey) {\n    this.apiKey = apiKey;\n    this.cache = new Map();\n    this.cacheExpiry = 5 * 60 * 1000; // 5 minutes\n  }\n\n  // Optimize list requests with smart pagination\n  async optimizedList(endpoint, options = {}) {\n    const {\n      limit = 50,\n      filters = {},\n      fields = null,\n      useCache = true\n    } = options;\n\n    // Generate cache key\n    const cacheKey = JSON.stringify({ endpoint, limit, filters, fields });\n    \n    if (useCache) {\n      const cached = this.cache.get(cacheKey);\n      if (cached && Date.now() - cached.timestamp < this.cacheExpiry) {\n        console.log('📦 Using cached response');\n        return cached.data;\n      }\n    }\n\n    // Build optimized query parameters\n    const params = new URLSearchParams({\n      limit: limit.toString(),\n      ...filters\n    });\n\n    // Add field filtering if supported\n    if (fields) {\n      params.set('fields', fields.join(','));\n    }\n\n    const url = `${endpoint}?${params.toString()}`;\n    \n    const start = performance.now();\n    const response = await fetch(url, {\n      headers: { 'x-api-key': this.apiKey }\n    });\n\n    if (!response.ok) {\n      throw new Error(`Request failed: ${response.status}`);\n    }\n\n    const data = await response.json();\n    const duration = performance.now() - start;\n    \n    console.log(`📊 Request completed in ${duration.toFixed(2)}ms (${data.data?.length || 0} items)`);\n\n    // Cache the response\n    if (useCache) {\n      this.cache.set(cacheKey, {\n        data,\n        timestamp: Date.now()\n      });\n    }\n\n    return data;\n  }\n\n  // Batch requests to reduce API calls\n  async batchRequests(requests, concurrency = 5) {\n    const results = [];\n    \n    for (let i = 0; i < requests.length; i += concurrency) {\n      const batch = requests.slice(i, i + concurrency);\n      \n      console.log(`Processing batch ${Math.floor(i / concurrency) + 1}/${Math.ceil(requests.length / concurrency)}`);\n      \n      const batchPromises = batch.map(async (request) => {\n        try {\n          return await request();\n        } catch (error) {\n          return { error: error.message };\n        }\n      });\n\n      const batchResults = await Promise.all(batchPromises);\n      results.push(...batchResults);\n      \n      // Small delay between batches\n      if (i + concurrency < requests.length) {\n        await new Promise(resolve => setTimeout(resolve, 100));\n      }\n    }\n\n    return results;\n  }\n\n  // Compress request payloads\n  async compressedRequest(endpoint, data, options = {}) {\n    const payload = JSON.stringify(data);\n    \n    // For large payloads, suggest compression\n    if (payload.length > 100000) { // 100KB\n      console.warn(`⚠️  Large payload detected: ${(payload.length / 1024).toFixed(1)}KB`);\n      console.warn('Consider breaking into smaller requests or using compression');\n    }\n\n    return await fetch(endpoint, {\n      method: 'POST',\n      headers: {\n        'x-api-key': this.apiKey,\n        'Content-Type': 'application/json',\n        ...options.headers\n      },\n      body: payload\n    });\n  }\n\n  // Smart field selection\n  getEssentialFields(entityType) {\n    const fieldMaps = {\n      workflow: ['id', 'name', 'isDeployed', 'updatedAt', 'runCount'],\n      user: ['id', 'name', 'email'],\n      workspace: ['id', 'name', 'memberCount']\n    };\n\n    return fieldMaps[entityType] || null;\n  }\n\n  // Clear cache\n  clearCache() {\n    this.cache.clear();\n    console.log('📦 Cache cleared');\n  }\n}\n\n// Usage\nconst optimizer = new RequestOptimizer('YOUR_API_KEY');\n\n// Optimized workflow list with caching and field selection\nconst workflows = await optimizer.optimizedList('/api/workflows', {\n  limit: 100,\n  filters: { status: 'deployed' },\n  fields: optimizer.getEssentialFields('workflow'),\n  useCache: true\n});\n\n// Batch multiple workflow creations\nconst workflowCreationRequests = workflowsData.map(data => \n  () => optimizer.compressedRequest('/api/workflows', data)\n);\n\nconst results = await optimizer.batchRequests(workflowCreationRequests, 3);\n```\n</Tab>\n<Tab value=\"Caching Strategy\">\n```javascript\n// Intelligent caching for API responses\nclass SmartCache {\n  constructor(options = {}) {\n    this.cache = new Map();\n    this.defaultTtl = options.defaultTtl || 5 * 60 * 1000; // 5 minutes\n    this.maxSize = options.maxSize || 1000;\n    this.hitCount = 0;\n    this.missCount = 0;\n  }\n\n  // Generate cache key from request details\n  generateKey(method, url, headers = {}, body = null) {\n    const keyData = {\n      method: method.toUpperCase(),\n      url,\n      relevantHeaders: {\n        'x-api-key': headers['x-api-key']?.slice(-8), // Last 8 chars only\n      },\n      body: body ? JSON.stringify(body) : null\n    };\n\n    return btoa(JSON.stringify(keyData));\n  }\n\n  // Check if request is cacheable\n  isCacheable(method, url, headers = {}) {\n    // Only cache GET requests\n    if (method.toUpperCase() !== 'GET') {\n      return false;\n    }\n\n    // Don't cache real-time or user-specific data\n    const noCachePatterns = [\n      '/status',\n      '/logs',\n      '/presence',\n      '/activity',\n      '/realtime'\n    ];\n\n    return !noCachePatterns.some(pattern => url.includes(pattern));\n  }\n\n  // Get cache entry\n  get(key) {\n    const entry = this.cache.get(key);\n    \n    if (!entry) {\n      this.missCount++;\n      return null;\n    }\n\n    // Check if expired\n    if (Date.now() > entry.expiry) {\n      this.cache.delete(key);\n      this.missCount++;\n      return null;\n    }\n\n    this.hitCount++;\n    entry.lastAccessed = Date.now();\n    return entry.data;\n  }\n\n  // Set cache entry\n  set(key, data, ttl = null) {\n    // Enforce max size\n    if (this.cache.size >= this.maxSize) {\n      this.evictOldest();\n    }\n\n    const entry = {\n      data,\n      expiry: Date.now() + (ttl || this.defaultTtl),\n      created: Date.now(),\n      lastAccessed: Date.now(),\n      accessCount: 1\n    };\n\n    this.cache.set(key, entry);\n  }\n\n  // Evict oldest entries\n  evictOldest() {\n    let oldest = null;\n    let oldestTime = Date.now();\n\n    for (const [key, entry] of this.cache.entries()) {\n      if (entry.lastAccessed < oldestTime) {\n        oldest = key;\n        oldestTime = entry.lastAccessed;\n      }\n    }\n\n    if (oldest) {\n      this.cache.delete(oldest);\n    }\n  }\n\n  // Invalidate cache entries by pattern\n  invalidate(pattern) {\n    const regex = new RegExp(pattern);\n    const keysToDelete = [];\n\n    for (const key of this.cache.keys()) {\n      if (regex.test(key)) {\n        keysToDelete.push(key);\n      }\n    }\n\n    keysToDelete.forEach(key => this.cache.delete(key));\n    console.log(`Invalidated ${keysToDelete.length} cache entries matching ${pattern}`);\n  }\n\n  // Get cache statistics\n  getStats() {\n    const total = this.hitCount + this.missCount;\n    const hitRate = total > 0 ? (this.hitCount / total) * 100 : 0;\n\n    return {\n      size: this.cache.size,\n      maxSize: this.maxSize,\n      hitCount: this.hitCount,\n      missCount: this.missCount,\n      hitRate: hitRate.toFixed(2) + '%',\n      efficiency: hitRate > 50 ? 'Good' : hitRate > 20 ? 'Fair' : 'Poor'\n    };\n  }\n}\n\n// Cached API client\nclass CachedApiClient {\n  constructor(apiKey, cacheOptions = {}) {\n    this.apiKey = apiKey;\n    this.cache = new SmartCache(cacheOptions);\n  }\n\n  async request(method, endpoint, options = {}) {\n    const url = `https://api.sim.dev${endpoint}`;\n    const headers = {\n      'x-api-key': this.apiKey,\n      'Content-Type': 'application/json',\n      ...options.headers\n    };\n\n    const cacheKey = this.cache.generateKey(method, url, headers, options.body);\n\n    // Try cache first for GET requests\n    if (this.cache.isCacheable(method, url)) {\n      const cached = this.cache.get(cacheKey);\n      if (cached) {\n        console.log('📦 Cache hit');\n        return cached;\n      }\n    }\n\n    console.log('🌐 Making API request');\n    \n    try {\n      const response = await fetch(url, {\n        method,\n        headers,\n        ...options\n      });\n\n      if (!response.ok) {\n        throw new Error(`HTTP ${response.status}: ${response.statusText}`);\n      }\n\n      const data = await response.json();\n\n      // Cache successful GET responses\n      if (this.cache.isCacheable(method, url)) {\n        const ttl = this.determineCacheTtl(endpoint);\n        this.cache.set(cacheKey, data, ttl);\n      }\n\n      // Invalidate related cache entries for write operations\n      if (method !== 'GET') {\n        this.invalidateRelatedCache(endpoint);\n      }\n\n      return data;\n    } catch (error) {\n      console.error('API request failed:', error);\n      throw error;\n    }\n  }\n\n  determineCacheTtl(endpoint) {\n    // Different TTLs for different types of data\n    const ttlMap = {\n      '/api/workflows': 2 * 60 * 1000,      // 2 minutes\n      '/api/templates': 10 * 60 * 1000,     // 10 minutes  \n      '/api/users': 5 * 60 * 1000,          // 5 minutes\n      '/api/workspaces': 10 * 60 * 1000     // 10 minutes\n    };\n\n    for (const [pattern, ttl] of Object.entries(ttlMap)) {\n      if (endpoint.includes(pattern)) {\n        return ttl;\n      }\n    }\n\n    return this.cache.defaultTtl;\n  }\n\n  invalidateRelatedCache(endpoint) {\n    // Invalidate related cache entries when data changes\n    const invalidationMap = {\n      '/api/workflows': ['workflows'],\n      '/api/templates': ['templates', 'workflows'],\n      '/api/workspaces': ['workspaces', 'workflows']\n    };\n\n    for (const [pattern, cachePatterns] of Object.entries(invalidationMap)) {\n      if (endpoint.includes(pattern)) {\n        cachePatterns.forEach(cachePattern => {\n          this.cache.invalidate(cachePattern);\n        });\n        break;\n      }\n    }\n  }\n\n  getCacheStats() {\n    return this.cache.getStats();\n  }\n\n  clearCache() {\n    this.cache = new SmartCache();\n    console.log('📦 Cache cleared');\n  }\n}\n\n// Usage\nconst apiClient = new CachedApiClient('YOUR_API_KEY', {\n  defaultTtl: 5 * 60 * 1000, // 5 minutes\n  maxSize: 500\n});\n\n// Cached requests\nconst workflows = await apiClient.request('GET', '/api/workflows');\nconst workflowsCached = await apiClient.request('GET', '/api/workflows'); // From cache\n\n// Check cache performance\nconsole.log('Cache stats:', apiClient.getCacheStats());\n\n// Clear cache when needed\napiClient.clearCache();\n```\n</Tab>\n</Tabs>\n\n## Production Monitoring\n\n### Health Checks and Monitoring\n\n```javascript\n// Production monitoring for API integration\nclass ApiHealthMonitor {\n  constructor(apiKey, options = {}) {\n    this.apiKey = apiKey;\n    this.interval = options.interval || 60000; // 1 minute\n    this.alertThreshold = options.alertThreshold || 5; // 5 failures\n    this.endpoints = options.endpoints || ['/api/workflows'];\n    \n    this.failures = new Map();\n    this.isMonitoring = false;\n    this.onAlert = options.onAlert || console.error;\n  }\n\n  start() {\n    if (this.isMonitoring) return;\n    \n    this.isMonitoring = true;\n    console.log('🔍 Starting API health monitoring...');\n    \n    this.monitoringInterval = setInterval(() => {\n      this.checkHealth();\n    }, this.interval);\n    \n    // Initial check\n    this.checkHealth();\n  }\n\n  stop() {\n    if (!this.isMonitoring) return;\n    \n    this.isMonitoring = false;\n    clearInterval(this.monitoringInterval);\n    console.log('⏹️ API health monitoring stopped');\n  }\n\n  async checkHealth() {\n    const results = await Promise.all(\n      this.endpoints.map(endpoint => this.checkEndpoint(endpoint))\n    );\n\n    const failedEndpoints = results.filter(r => !r.healthy);\n    \n    if (failedEndpoints.length > 0) {\n      this.handleFailures(failedEndpoints);\n    } else {\n      // Reset failure counts on success\n      this.failures.clear();\n    }\n\n    this.logHealthStatus(results);\n  }\n\n  async checkEndpoint(endpoint) {\n    const start = Date.now();\n    \n    try {\n      const response = await fetch(`https://api.sim.dev${endpoint}?limit=1`, {\n        headers: { 'x-api-key': this.apiKey },\n        timeout: 10000\n      });\n\n      const duration = Date.now() - start;\n      const healthy = response.ok && duration < 5000; // Must be OK and under 5s\n\n      return {\n        endpoint,\n        healthy,\n        status: response.status,\n        duration,\n        timestamp: new Date().toISOString()\n      };\n    } catch (error) {\n      return {\n        endpoint,\n        healthy: false,\n        status: 0,\n        duration: Date.now() - start,\n        error: error.message,\n        timestamp: new Date().toISOString()\n      };\n    }\n  }\n\n  handleFailures(failedEndpoints) {\n    failedEndpoints.forEach(failure => {\n      const count = (this.failures.get(failure.endpoint) || 0) + 1;\n      this.failures.set(failure.endpoint, count);\n\n      if (count >= this.alertThreshold) {\n        this.triggerAlert(failure, count);\n      }\n    });\n  }\n\n  triggerAlert(failure, count) {\n    const alert = {\n      type: 'API_HEALTH_ALERT',\n      endpoint: failure.endpoint,\n      failureCount: count,\n      lastError: failure.error,\n      status: failure.status,\n      timestamp: failure.timestamp,\n      severity: count >= 10 ? 'CRITICAL' : 'WARNING'\n    };\n\n    console.error(`🚨 API Health Alert:`, alert);\n    this.onAlert(alert);\n  }\n\n  logHealthStatus(results) {\n    const healthy = results.filter(r => r.healthy).length;\n    const total = results.length;\n    \n    const avgDuration = results.reduce((sum, r) => sum + r.duration, 0) / total;\n    \n    console.log(`💓 API Health: ${healthy}/${total} endpoints healthy (avg ${avgDuration.toFixed(0)}ms)`);\n    \n    results.forEach(result => {\n      const icon = result.healthy ? '✅' : '❌';\n      const duration = `${result.duration}ms`;\n      const status = result.status || 'ERROR';\n      \n      console.log(`  ${icon} ${result.endpoint}: ${status} (${duration})`);\n    });\n  }\n\n  getHealthReport() {\n    return {\n      monitoring: this.isMonitoring,\n      failures: Object.fromEntries(this.failures),\n      lastCheck: new Date().toISOString()\n    };\n  }\n}\n\n// Usage in production\nconst healthMonitor = new ApiHealthMonitor('YOUR_API_KEY', {\n  interval: 30000, // Check every 30 seconds\n  alertThreshold: 3,\n  endpoints: ['/api/workflows', '/api/templates', '/api/workspaces'],\n  onAlert: (alert) => {\n    // Send to monitoring service (PagerDuty, Slack, etc.)\n    console.error('PRODUCTION ALERT:', alert);\n    \n    // Send to Slack webhook\n    fetch(process.env.SLACK_WEBHOOK_URL, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        text: `🚨 API Health Alert: ${alert.endpoint} failing (${alert.failureCount} failures)`\n      })\n    });\n  }\n});\n\n// Start monitoring in production\nhealthMonitor.start();\n\n// Stop monitoring on app shutdown\nprocess.on('SIGTERM', () => {\n  healthMonitor.stop();\n});\n```\n\nThis comprehensive troubleshooting guide provides developers with the tools and techniques needed to diagnose and resolve API integration issues effectively. Use these patterns and monitoring strategies to build robust, reliable integrations with the Sim API.\n\n## Next Steps\n\n- [Error Codes](/docs/api/error-codes) - Complete API error reference\n- [Rate Limits](/docs/api/rate-limits) - Manage API usage effectively  \n- [SDKs](/docs/api/sdks/javascript) - Use client libraries with built-in error handling\n- [Authentication](/docs/api/authentication) - Ensure proper API access setup"
