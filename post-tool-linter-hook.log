          "+                isDeployed: true,",
          "+                deployedAt: new Date(),",
          "+                updatedAt: new Date(),",
          "+              })",
          "+              .where(eq(workflow.id, workflowId))",
          "+",
          "+            deployedIds.push(workflowId)",
