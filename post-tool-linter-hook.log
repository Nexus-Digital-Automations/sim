    "content": "/**\n * Mobile Shell Layout Component\n * \n * Provides the main mobile application shell with:\n * - Bottom navigation for primary actions\n * - Mobile-optimized header with safe area support\n * - Responsive content area with proper spacing\n * - Touch-friendly interaction patterns\n * - Progressive Web App integration\n * \n * Features:\n * - iOS safe area support (notch, dynamic island)\n * - Android navigation bar adaptation\n * - Gesture navigation compatibility\n * - Accessibility optimizations for mobile screen readers\n * - Performance optimized for mobile devices\n */\n\n'use client'\n\nimport { ReactNode, useEffect, useState } from 'react'\nimport { usePathname } from 'next/navigation'\nimport { cn } from '@/lib/utils'\nimport { MobileHeader } from './mobile-header'\nimport { BottomNavigation } from './bottom-navigation'\nimport { InstallPrompt } from './install-prompt'\n\ninterface MobileShellProps {\n  children: ReactNode\n  className?: string\n  showBottomNav?: boolean\n  showInstallPrompt?: boolean\n}\n\n/**\n * Main mobile application shell providing native-like mobile experience\n * \n * Layout Architecture:\n * ┌─────────────────────────────────┐\n * │          Mobile Header          │\n * ├─────────────────────────────────┤\n * │                                 │\n * │         Content Area            │\n * │     (Scrollable + Safe)         │\n * │                                 │\n * ├─────────────────────────────────┤\n * │       Bottom Navigation         │\n * └─────────────────────────────────┘\n */\nexport function MobileShell({\n  children,\n  className,\n  showBottomNav = true,\n  showInstallPrompt = true,\n}: MobileShellProps) {\n  const pathname = usePathname()\n  const [isMobile, setIsMobile] = useState(false)\n  const [isStandalone, setIsStandalone] = useState(false)\n\n  // Detect mobile viewport and PWA mode\n  useEffect(() => {\n    const checkMobile = () => {\n      setIsMobile(window.innerWidth <= 768)\n    }\n\n    const checkStandalone = () => {\n      // Check if running as PWA (standalone mode)\n      setIsStandalone(\n        window.matchMedia('(display-mode: standalone)').matches ||\n        (window.navigator as any).standalone === true\n      )\n    }\n\n    checkMobile()\n    checkStandalone()\n\n    window.addEventListener('resize', checkMobile)\n    \n    return () => window.removeEventListener('resize', checkMobile)\n  }, [])\n\n  // Don't show mobile shell on desktop\n  if (!isMobile) {\n    return <>{children}</>\n  }\n\n  return (\n    <div \n      className={cn(\n        'mobile-shell min-h-screen flex flex-col',\n        'bg-background text-foreground',\n        // Safe area support for iOS devices\n        'env-safe supports-[padding:env(safe-area-inset-top)]:pt-[env(safe-area-inset-top)]',\n        'supports-[padding:env(safe-area-inset-bottom)]:pb-[env(safe-area-inset-bottom)]',\n        'supports-[padding:env(safe-area-inset-left)]:pl-[env(safe-area-inset-left)]',\n        'supports-[padding:env(safe-area-inset-right)]:pr-[env(safe-area-inset-right)]',\n        className\n      )}\n    >\n      {/* PWA Install Prompt */}\n      {showInstallPrompt && !isStandalone && (\n        <InstallPrompt />\n      )}\n\n      {/* Mobile Header */}\n      <MobileHeader \n        currentPath={pathname}\n        isStandalone={isStandalone}\n        className=\"flex-shrink-0\"\n      />\n\n      {/* Main Content Area */}\n      <main \n        className={cn(\n          'flex-1 flex flex-col overflow-hidden',\n          // Bottom navigation spacing\n          showBottomNav ? 'pb-16' : 'pb-4',\n          // Content padding and safe areas\n          'px-4 py-2',\n        )}\n        role=\"main\"\n        aria-label=\"Main content\"\n      >\n        {/* Scrollable content wrapper */}\n        <div className=\"flex-1 overflow-y-auto overflow-x-hidden\">\n          {children}\n        </div>\n      </main>\n\n      {/* Bottom Navigation */}\n      {showBottomNav && (\n        <BottomNavigation \n          currentPath={pathname}\n          className=\"flex-shrink-0\"\n        />\n      )}\n\n      {/* Mobile-specific global styles */}\n      <style jsx global>{`\n        /* Prevent iOS Safari bounce scrolling */\n        body {\n          overscroll-behavior: none;\n          -webkit-overflow-scrolling: touch;\n        }\n\n        /* iOS-specific fixes */\n        @supports (-webkit-touch-callout: none) {\n          .mobile-shell {\n            /* Fix iOS viewport height issues */\n            min-height: -webkit-fill-available;\n          }\n        }\n\n        /* Hide scrollbars on mobile for cleaner look */\n        @media (max-width: 768px) {\n          ::-webkit-scrollbar {\n            display: none;\n          }\n          * {\n            -ms-overflow-style: none;\n            scrollbar-width: none;\n          }\n        }\n\n        /* Touch-friendly focus styles */\n        @media (max-width: 768px) {\n          *:focus {\n            outline: 2px solid hsl(var(--primary));\n            outline-offset: 2px;\n          }\n          \n          button:focus,\n          [role=\"button\"]:focus {\n            transform: scale(0.98);\n            transition: transform 0.1s ease;\n          }\n        }\n\n        /* Mobile typography improvements */\n        @media (max-width: 768px) {\n          body {\n            font-size: 16px; /* Prevent iOS zoom on inputs */\n            line-height: 1.5;\n          }\n          \n          h1, h2, h3, h4, h5, h6 {\n            line-height: 1.3;\n            margin-bottom: 0.5em;\n          }\n        }\n      `}</style>\n    </div>\n  )\n}\n\n/**\n * Custom hook for detecting mobile environment and capabilities\n */\nexport function useMobileDetection() {\n  const [detection, setDetection] = useState({\n    isMobile: false,\n    isTablet: false,\n    isStandalone: false,\n    hasNotch: false,\n    supportsTouch: false,\n    deviceOrientation: 'portrait' as 'portrait' | 'landscape',\n  })\n\n  useEffect(() => {\n    const updateDetection = () => {\n      const width = window.innerWidth\n      const height = window.innerHeight\n      \n      setDetection({\n        isMobile: width <= 768,\n        isTablet: width > 768 && width <= 1024,\n        isStandalone: window.matchMedia('(display-mode: standalone)').matches || \n                     (window.navigator as any).standalone === true,\n        hasNotch: window.CSS?.supports('padding', 'env(safe-area-inset-top)') || false,\n        supportsTouch: 'ontouchstart' in window,\n        deviceOrientation: width > height ? 'landscape' : 'portrait',\n      })\n    }\n\n    updateDetection()\n    \n    window.addEventListener('resize', updateDetection)\n    window.addEventListener('orientationchange', updateDetection)\n    \n    return () => {\n      window.removeEventListener('resize', updateDetection)\n      window.removeEventListener('orientationchange', updateDetection)\n    }\n  }, [])\n\n  return detection\n}",
    "structuredPatch": []
  }
}
