  "session_id": "6040cd32-c01d-4a82-a9d9-eb80713ad6f0",
  "transcript_path": "/Users/jeremyparker/.claude/projects/-Users-jeremyparker-Desktop-Claude-Coding-Projects-sim/6040cd32-c01d-4a82-a9d9-eb80713ad6f0.jsonl",
  "cwd": "/Users/jeremyparker/Desktop/Claude Coding Projects/sim",
  "hook_event_name": "PostToolUse",
