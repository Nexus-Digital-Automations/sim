        "old_string": "                    <label className='font-medium text-muted-foreground text-xs'>Difficulty</label>\n                    <select\n                      value={selectedFilters.difficulty || ''}\n                      onChange={(e) =>\n                        setSelectedFilters((prev) => ({\n                          ...prev,\n                          difficulty:\n                            (e.target.value as DocumentationItem['difficulty']) || undefined,\n                        }))\n                      }\n                      className='mt-1 w-full rounded border px-2 py-1 text-sm'",
        "new_string": "                    <label htmlFor='difficulty-select' className='font-medium text-muted-foreground text-xs'>Difficulty</label>\n                    <select\n                      id='difficulty-select'\n                      value={selectedFilters.difficulty || ''}\n                      onChange={(e) =>\n                        setSelectedFilters((prev) => ({\n                          ...prev,\n                          difficulty:\n                            (e.target.value as DocumentationItem['difficulty']) || undefined,\n                        }))\n                      }\n                      className='mt-1 w-full rounded border px-2 py-1 text-sm'",
