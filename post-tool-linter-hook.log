          "+            logger.info(`[${requestId}] Copied workflow ${workflowData.id} to ${newWorkflowId}`)",
          "+          } catch (error) {",
          "+            logger.error(`[${requestId}] Failed to copy workflow ${workflowData.id}`, error)",
          "+          }",
          "+        }",
          "+        results = copiedWorkflows.map(({ originalId, newId }) => ({ ",
          "+          id: originalId, ",
          "+          status: 'copied', ",
