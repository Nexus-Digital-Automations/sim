      "warm_lead_assignment": {
        "id": "warm_assign_001",
        "type": "function",
        "position": { "x": 1300, "y": 200 },
        "data": {
          "title": "Assign to Sales Rep",
          "description": "Assign warm leads to available sales representatives using round-robin"
        },
        "subBlocks": {
          "code": {
            "type": "javascript",
            "value": `
              /**
               * Round-robin sales rep assignment logic
               * Assigns leads to sales reps based on availability and territory
               */
              function assignSalesRep(lead) {
                // Define sales team with territories and capacity
                const salesTeam = [
                  {
                    id: 'rep_001',
                    name: 'Sarah Johnson',
                    email: 'sarah.johnson@company.com',
                    territories: ['north-america', 'europe'],
                    capacity: 15,
                    current_leads: 8,
                    specialties: ['technology', 'healthcare']
                  },
                  {
                    id: 'rep_002', 
                    name: 'Mike Chen',
                    email: 'mike.chen@company.com',
                    territories: ['north-america', 'asia-pacific'],
                    capacity: 20,
                    current_leads: 12,
                    specialties: ['financial-services', 'manufacturing']
                  },
                  {
                    id: 'rep_003',
                    name: 'Emma Rodriguez',
                    email: 'emma.rodriguez@company.com', 
                    territories: ['europe', 'latin-america'],
                    capacity: 18,
                    current_leads: 5,
                    specialties: ['technology', 'education']
                  }
                ];
                
                // Filter reps by territory and capacity
                const availableReps = salesTeam.filter(rep => {
                  return rep.territories.includes(lead.region?.toLowerCase()) && 
                         rep.current_leads < rep.capacity;
                });
                
                if (availableReps.length === 0) {
                  // Fallback to least loaded rep
                  const fallbackRep = salesTeam.reduce((min, rep) => 
                    rep.current_leads < min.current_leads ? rep : min
                  );
                  return { assigned_rep: fallbackRep, assignment_reason: 'capacity-fallback' };
                }
                
                // Prioritize by specialty match
                const specialtyMatch = availableReps.find(rep =>
                  rep.specialties.includes(lead.industry?.toLowerCase())
                );
                
                if (specialtyMatch) {
                  return { 
                    assigned_rep: specialtyMatch, 
                    assignment_reason: 'specialty-match' 
                  };
                }
                
                // Round-robin assignment (least loaded)
                const assignedRep = availableReps.reduce((min, rep) =>
                  rep.current_leads < min.current_leads ? rep : min
                );
                
                return { 
                  assigned_rep: assignedRep,
                  assignment_reason: 'round-robin'
                };
              }
              
              const assignment = assignSalesRep(lead);
              return {
                ...lead,
                assigned_rep_id: assignment.assigned_rep.id,
                assigned_rep_name: assignment.assigned_rep.name,
                assigned_rep_email: assignment.assigned_rep.email,
                assignment_reason: assignment.assignment_reason,
                assigned_at: new Date().toISOString()
              };
            `
          }
        }
