      "lead_scoring": {
        "id": "scoring_001",
        "type": "function", 
        "position": { "x": 700, "y": 100 },
        "data": {
          "title": "Lead Scoring Engine",
          "description": "Calculate lead score based on demographic and behavioral data"
        },
        "subBlocks": {
          "code": {
            "type": "javascript",
            "value": `
              /**
               * Lead Scoring Algorithm
               * Calculates lead score based on multiple criteria
               * @param {Object} lead - Lead data object
               * @returns {Object} - Scored lead with qualification status
               */
              function calculateLeadScore(lead) {
                let score = 0;
                const scoring = {
                  // Company Size Scoring
                  company_size: {
                    '1-10': 10,
                    '11-50': 25, 
                    '51-200': 40,
                    '201-1000': 50,
                    '1000+': 60
                  },
                  // Industry Scoring
                  industry: {
                    'technology': 50,
                    'healthcare': 45,
                    'financial-services': 45,
                    'manufacturing': 35,
                    'education': 30,
                    'other': 20
                  },
                  // Job Title Scoring
                  job_title: {
                    'ceo|president|founder': 60,
                    'cto|vp-technology|head-of': 55,
                    'director|manager': 40,
                    'coordinator|assistant|intern': 15
                  },
                  // Geographic Scoring
                  location: {
                    'north-america': 50,
                    'europe': 45,
                    'asia-pacific': 35,
                    'other': 25
                  }
                };
                
                // Calculate company size score
                if (lead.company_size && scoring.company_size[lead.company_size]) {
                  score += scoring.company_size[lead.company_size];
                }
                
                // Calculate industry score
                if (lead.industry && scoring.industry[lead.industry.toLowerCase()]) {
                  score += scoring.industry[lead.industry.toLowerCase()];
                }
                
                // Calculate job title score (regex matching)
                if (lead.job_title) {
                  const title = lead.job_title.toLowerCase();
                  for (const [pattern, points] of Object.entries(scoring.job_title)) {
                    if (new RegExp(pattern, 'i').test(title)) {
                      score += points;
                      break;
                    }
                  }
                }
                
                // Calculate location score
                if (lead.country && scoring.location[lead.country.toLowerCase()]) {
                  score += scoring.location[lead.country.toLowerCase()];
                }
                
                // Behavioral scoring bonuses
                if (lead.website_visits > 5) score += 20;
                if (lead.email_opens > 3) score += 15;
                if (lead.content_downloads > 0) score += 25;
                if (lead.demo_requested) score += 40;
                
                // Determine qualification status
                let qualification = 'unqualified';
                if (score >= 80) qualification = 'hot';
                else if (score >= 60) qualification = 'warm'; 
                else if (score >= 40) qualification = 'qualified';
                
                return {
                  ...lead,
                  lead_score: score,
                  qualification_status: qualification,
                  scored_at: new Date().toISOString(),
                  scoring_breakdown: {
                    company_size: scoring.company_size[lead.company_size] || 0,
                    industry: scoring.industry[lead.industry?.toLowerCase()] || 0,
                    job_title: 'calculated',
                    location: scoring.location[lead.country?.toLowerCase()] || 0
                  }
                };
              }
              
              // Execute scoring
              const scoredLead = calculateLeadScore(lead);
              return scoredLead;
            `
          }
        }
      },
