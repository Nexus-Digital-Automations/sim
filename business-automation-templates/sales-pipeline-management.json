      "forecast_update": {
        "id": "forecast_001",
        "type": "function",
        "position": { "x": 1300, "y": 400 },
        "data": {
          "title": "Sales Forecast Update",
          "description": "Update sales forecast based on deal scoring and probability adjustments"
        },
        "subBlocks": {
          "code": {
            "type": "javascript",
            "value": `
              /**
               * Sales Forecast Calculator
               * Updates forecast based on deal quality scores and risk assessments
               */
              function updateSalesForecast(opportunities, currentPeriod) {
                const forecast = {
                  period: currentPeriod,
                  generated_at: new Date().toISOString(),
                  methodology: 'ai_enhanced_probability',
                  confidence_level: 0.85
                };
                
                // Calculate adjusted probabilities based on deal scores
                const forecastData = opportunities.map(opp => {
                  const originalProbability = opp.probability || 0.5;
                  const dealScore = opp.deal_score || 50;
                  const riskLevel = opp.risk_level || 'medium';
                  
                  // Adjust probability based on deal score
                  let scoringAdjustment = 0;
                  if (dealScore >= 80) scoringAdjustment = 0.15;
                  else if (dealScore >= 70) scoringAdjustment = 0.10;
                  else if (dealScore >= 60) scoringAdjustment = 0.05;
                  else if (dealScore < 40) scoringAdjustment = -0.20;
                  else if (dealScore < 50) scoringAdjustment = -0.10;
                  
                  // Risk level adjustments
                  let riskAdjustment = 0;
                  if (riskLevel === 'high') riskAdjustment = -0.25;
                  else if (riskLevel === 'medium') riskAdjustment = -0.10;
                  else if (riskLevel === 'low') riskAdjustment = 0.05;
                  
                  // Calculate enhanced probability
                  const enhancedProbability = Math.max(0, Math.min(1, 
                    originalProbability + scoringAdjustment + riskAdjustment
                  ));
                  
                  return {
                    ...opp,
                    original_probability: originalProbability,
                    enhanced_probability: enhancedProbability,
                    probability_adjustment: enhancedProbability - originalProbability,
                    weighted_value: opp.amount * enhancedProbability
                  };
                });
                
                // Calculate forecast totals
                const totalPipeline = forecastData.reduce((sum, opp) => sum + opp.amount, 0);
                const originalForecast = forecastData.reduce((sum, opp) => sum + (opp.amount * opp.original_probability), 0);
                const enhancedForecast = forecastData.reduce((sum, opp) => sum + opp.weighted_value, 0);
                
                // Calculate forecast by categories
                const forecastByStage = {};
                const forecastByRisk = { low: 0, medium: 0, high: 0 };
                const forecastByScore = { high: 0, medium: 0, low: 0 };
                
                forecastData.forEach(opp => {
                  // By stage
                  if (!forecastByStage[opp.stage]) forecastByStage[opp.stage] = 0;
                  forecastByStage[opp.stage] += opp.weighted_value;
                  
                  // By risk level
                  forecastByRisk[opp.risk_level] += opp.weighted_value;
                  
                  // By score range
                  const scoreCategory = opp.deal_score >= 70 ? 'high' : opp.deal_score >= 50 ? 'medium' : 'low';
                  forecastByScore[scoreCategory] += opp.weighted_value;
                });
                
                return {
                  ...forecast,
                  summary: {
                    total_pipeline: totalPipeline,
                    original_forecast: originalForecast,
                    enhanced_forecast: enhancedForecast,
                    forecast_improvement: enhancedForecast - originalForecast,
                    improvement_percentage: ((enhancedForecast - originalForecast) / originalForecast) * 100,
                    deal_count: opportunities.length,
                    average_deal_size: totalPipeline / opportunities.length,
                    confidence_range: {
                      conservative: enhancedForecast * 0.85,
                      optimistic: enhancedForecast * 1.15
                    }
                  },
                  breakdown: {
                    by_stage: forecastByStage,
                    by_risk_level: forecastByRisk,
                    by_score_range: forecastByScore
                  },
                  deals: forecastData.slice(0, 20), // Top 20 deals for reporting
                  recommendations: generateForecastRecommendations(forecastData)
                };
              }
              
              function generateForecastRecommendations(deals) {
                const recommendations = [];
                
                const highValueAtRiskDeals = deals.filter(deal => 
                  deal.amount > 50000 && deal.risk_level === 'high'
                ).length;
                
                if (highValueAtRiskDeals > 0) {
                  recommendations.push(\`Focus on \${highValueAtRiskDeals} high-value at-risk deals\`);
                }
                
                const lowScoreDeals = deals.filter(deal => deal.deal_score < 50).length;
                if (lowScoreDeals > deals.length * 0.3) {
                  recommendations.push('Consider pipeline quality improvement initiatives');
                }
                
                const soonClosingDeals = deals.filter(deal => {
                  const daysToClose = (new Date(deal.close_date) - Date.now()) / (1000 * 60 * 60 * 24);
                  return daysToClose <= 30 && deal.enhanced_probability > 0.6;
                }).length;
                
                if (soonClosingDeals > 0) {
                  recommendations.push(\`Prioritize \${soonClosingDeals} deals closing within 30 days\`);
                }
                
                return recommendations;
              }
              
              // Execute forecast calculation (this would typically receive all opportunities)
              const forecastResult = updateSalesForecast([opportunity], 'current_quarter');
              return { ...opportunity, forecast_data: forecastResult };
            `
          }
        }
      },
