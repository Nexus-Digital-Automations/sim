      "deal_scoring": {
        "id": "score_001",
        "type": "function",
        "position": { "x": 500, "y": 300 },
        "data": {
          "title": "Deal Quality Scoring Engine",
          "description": "Calculate deal quality score based on multiple criteria and historical data"
        },
        "subBlocks": {
          "code": {
            "type": "javascript",
            "value": `
              /**
               * Advanced Deal Quality Scoring Algorithm
               * Calculates comprehensive deal score based on multiple factors
               * @param {Object} opportunity - Opportunity data from CRM
               * @param {Object} account - Associated account/company data  
               * @param {Object} contact - Primary contact data
               * @param {Array} activities - Recent sales activities
               * @returns {Object} - Scored opportunity with risk assessment
               */
              function calculateDealScore(opportunity, account, contact, activities) {
                let totalScore = 0;
                const maxScore = 100;
                const scoringFactors = {
                  // Account Quality (25 points)
                  account_fit: {
                    company_size: {
                      'enterprise_1000+': 25,
                      'mid_market_200-1000': 20,
                      'smb_50-200': 15,
                      'small_10-50': 10,
                      'micro_1-10': 5
                    },
                    industry_match: {
                      'perfect_match': 25,
                      'good_match': 20,
                      'partial_match': 15,
                      'weak_match': 10,
                      'poor_match': 5
                    }
                  },
                  
                  // Contact Quality (20 points)
                  decision_maker: {
                    'c_level': 20,
                    'vp_director': 17,
                    'manager': 12,
                    'individual_contributor': 8,
                    'unknown': 5
                  },
                  
                  // Opportunity Characteristics (25 points)
                  deal_size: {
                    score_multiplier: Math.min(25, (opportunity.amount / 50000) * 10) // $50k = 10 points, scales up
                  },
                  competition: {
                    'sole_vendor': 15,
                    'preferred_vendor': 12,
                    'competitive_bid': 8,
                    'long_list': 5,
                    'unknown': 10
                  },
                  
                  // Sales Process (20 points) 
                  discovery_completion: {
                    'complete': 20,
                    'mostly_complete': 15,
                    'partial': 10,
                    'minimal': 5,
                    'not_started': 0
                  },
                  
                  // Engagement Level (10 points)
                  recent_activity: calculateActivityScore(activities)
                };
                
                // Calculate account fit score
                const companySize = account.employee_count || 0;
                let companySizeCategory;
                if (companySize >= 1000) companySizeCategory = 'enterprise_1000+';
                else if (companySize >= 200) companySizeCategory = 'mid_market_200-1000';
                else if (companySize >= 50) companySizeCategory = 'smb_50-200';
                else if (companySize >= 10) companySizeCategory = 'small_10-50';
                else companySizeCategory = 'micro_1-10';
                
                totalScore += scoringFactors.account_fit.company_size[companySizeCategory] || 10;
                
                // Industry match scoring
                const industryMatch = determineIndustryMatch(account.industry);
                totalScore += scoringFactors.account_fit.industry_match[industryMatch];
                
                // Decision maker scoring
                const decisionMakerLevel = categorizeDecisionMaker(contact.title);
                totalScore += scoringFactors.decision_maker[decisionMakerLevel];
                
                // Deal size scoring
                totalScore += Math.min(25, (opportunity.amount / 50000) * 10);
                
                // Competition level
                const competitionLevel = opportunity.competition_status || 'unknown';
                totalScore += scoringFactors.competition[competitionLevel] || 10;
                
                // Discovery completion
                const discoveryStatus = assessDiscoveryCompletion(opportunity, activities);
                totalScore += scoringFactors.discovery_completion[discoveryStatus];
                
                // Recent activity score
                totalScore += calculateActivityScore(activities);
                
                // Normalize to 100-point scale
                const finalScore = Math.min(maxScore, Math.round(totalScore));
                
                // Determine risk level and recommendations
                const riskAssessment = assessDealRisk(opportunity, finalScore, activities);
                const nextActions = generateNextActions(opportunity, riskAssessment);
                
                return {
                  ...opportunity,
                  deal_score: finalScore,
                  risk_level: riskAssessment.level,
                  risk_factors: riskAssessment.factors,
                  recommended_actions: nextActions,
                  score_breakdown: {
                    account_quality: Math.round((totalScore * 0.25)),
                    contact_quality: Math.round((totalScore * 0.20)),
                    opportunity_strength: Math.round((totalScore * 0.25)),
                    sales_process: Math.round((totalScore * 0.20)),
                    engagement_level: Math.round((totalScore * 0.10))
                  },
                  scored_at: new Date().toISOString()
                };
              }
              
              function calculateActivityScore(activities) {
                if (!activities || activities.length === 0) return 2;
                
                const recentActivities = activities.filter(activity => {
                  const activityDate = new Date(activity.date);
                  const daysAgo = (Date.now() - activityDate) / (1000 * 60 * 60 * 24);
                  return daysAgo <= 14; // Last 2 weeks
                });
                
                let activityScore = 0;
                recentActivities.forEach(activity => {
                  switch (activity.type) {
                    case 'demo': activityScore += 3; break;
                    case 'meeting': activityScore += 2; break;
                    case 'call': activityScore += 1.5; break;
                    case 'email': activityScore += 1; break;
                    case 'proposal': activityScore += 4; break;
                    default: activityScore += 0.5;
                  }
                });
                
                return Math.min(10, activityScore);
              }
              
              function determineIndustryMatch(industry) {
                const targetIndustries = ['technology', 'healthcare', 'financial-services'];
                const goodMatch = ['manufacturing', 'education', 'retail'];
                
                if (targetIndustries.includes(industry?.toLowerCase())) return 'perfect_match';
                if (goodMatch.includes(industry?.toLowerCase())) return 'good_match';
                if (industry) return 'partial_match';
                return 'unknown';
              }
              
              function categorizeDecisionMaker(title) {
                if (!title) return 'unknown';
                const titleLower = title.toLowerCase();
                
                if (/ceo|president|founder|owner/.test(titleLower)) return 'c_level';
                if (/cto|cfo|coo|vp|vice.president|director/.test(titleLower)) return 'vp_director';
                if (/manager|head.of|lead/.test(titleLower)) return 'manager';
                return 'individual_contributor';
              }
              
              function assessDiscoveryCompletion(opportunity, activities) {
                // Assess based on discovery-related activities and opportunity fields
                const discoveryIndicators = {
                  needs_identified: !!opportunity.identified_needs,
                  budget_qualified: !!opportunity.budget_confirmed,
                  timeline_established: !!opportunity.timeline_confirmed,
                  decision_process_mapped: !!opportunity.decision_process,
                  stakeholders_identified: !!opportunity.key_stakeholders
                };
                
                const completionCount = Object.values(discoveryIndicators).filter(Boolean).length;
                const completionPercentage = completionCount / 5;
                
                if (completionPercentage >= 0.8) return 'complete';
                if (completionPercentage >= 0.6) return 'mostly_complete';
                if (completionPercentage >= 0.4) return 'partial';
                if (completionPercentage > 0) return 'minimal';
                return 'not_started';
              }
              
              function assessDealRisk(opportunity, score, activities) {
                const riskFactors = [];
                let riskLevel = 'low';
                
                // Time-based risk factors
                const daysToClose = Math.floor((new Date(opportunity.close_date) - Date.now()) / (1000 * 60 * 60 * 24));
                if (daysToClose < 7 && score < 60) {
                  riskFactors.push('Low score with close date approaching');
                  riskLevel = 'high';
                }
                
                // Activity risk factors
                const lastActivity = activities?.[0]?.date;
                if (lastActivity) {
                  const daysSinceActivity = Math.floor((Date.now() - new Date(lastActivity)) / (1000 * 60 * 60 * 24));
                  if (daysSinceActivity > 14) {
                    riskFactors.push('No recent activity');
                    riskLevel = riskLevel === 'high' ? 'high' : 'medium';
                  }
                }
                
                // Score-based risk assessment
                if (score < 40) {
                  riskFactors.push('Low deal quality score');
                  riskLevel = 'high';
                } else if (score < 65) {
                  riskFactors.push('Moderate deal quality concerns');
                  riskLevel = riskLevel === 'high' ? 'high' : 'medium';
                }
                
                return { level: riskLevel, factors: riskFactors };
              }
              
              function generateNextActions(opportunity, riskAssessment) {
                const actions = [];
                
                if (riskAssessment.level === 'high') {
                  actions.push('Schedule urgent stakeholder meeting');
                  actions.push('Reassess opportunity qualification');
                  actions.push('Consider deal rescue strategies');
                }
                
                if (opportunity.stage === 'proposal' && !opportunity.proposal_sent) {
                  actions.push('Prepare and send proposal');
                }
                
                if (!opportunity.next_meeting_scheduled) {
                  actions.push('Schedule follow-up meeting');
                }
                
                return actions;
              }
              
              // Execute scoring
              const scoredOpportunity = calculateDealScore(opportunity, account, contact, activities);
              return scoredOpportunity;
            `
          }
        }
      },
      "stage_progression": {
