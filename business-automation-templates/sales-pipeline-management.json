      "proposal_generator": {
        "id": "proposal_001",
        "type": "function",
        "position": { "x": 900, "y": 200 },
        "data": {
          "title": "Automated Proposal Generator",
          "description": "Generate customized proposals and quotes based on opportunity data"
        },
        "subBlocks": {
          "code": {
            "type": "javascript",
            "value": `
              /**
               * Intelligent Proposal Generator
               * Creates customized proposals based on opportunity context
               */
              function generateProposal(opportunity, account, contact, products) {
                const proposalData = {
                  // Header Information
                  proposal_id: generateProposalId(),
                  created_date: new Date().toISOString(),
                  valid_until: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString(), // 30 days
                  
                  // Client Information
                  client: {
                    company_name: account.name,
                    contact_name: \`\${contact.first_name} \${contact.last_name}\`,
                    contact_title: contact.title,
                    contact_email: contact.email,
                    company_address: account.billing_address,
                    industry: account.industry,
                    company_size: account.employee_count
                  },
                  
                  // Opportunity Context
                  opportunity_context: {
                    opportunity_name: opportunity.name,
                    estimated_value: opportunity.amount,
                    close_date: opportunity.close_date,
                    probability: opportunity.probability,
                    identified_needs: opportunity.identified_needs || [],
                    success_criteria: opportunity.success_criteria || [],
                    decision_criteria: opportunity.decision_criteria || []
                  },
                  
                  // Customized Solution
                  solution: buildSolutionRecommendation(opportunity, account, products),
                  
                  // Pricing Structure
                  pricing: calculatePricing(opportunity, account, products),
                  
                  // Implementation Plan
                  implementation: generateImplementationPlan(opportunity, account),
                  
                  // Terms and Conditions
                  terms: generateTermsAndConditions(opportunity, account),
                  
                  // Next Steps
                  next_steps: [
                    'Review proposal with your team',
                    'Schedule follow-up meeting to discuss questions',
                    'Provide feedback on solution recommendations',
                    'Confirm implementation timeline preferences'
                  ]
                };
                
                return {
                  proposal_data: proposalData,
                  template_type: determineProposalTemplate(opportunity, account),
                  personalization_level: 'high',
                  generated_at: new Date().toISOString()
                };
              }
              
              function generateProposalId() {
                const timestamp = Date.now().toString(36);
                const random = Math.random().toString(36).substr(2, 5);
                return \`PROP-\${timestamp}-\${random}\`.toUpperCase();
              }
              
              function buildSolutionRecommendation(opportunity, account, products) {
                // Intelligent product selection based on needs and company profile
                const recommendedProducts = products.filter(product => {
                  // Match products to identified needs
                  const needsMatch = opportunity.identified_needs?.some(need => 
                    product.use_cases.includes(need.toLowerCase())
                  );
                  
                  // Match products to company size
                  const sizeMatch = product.target_company_size.includes(
                    categorizeCompanySize(account.employee_count)
                  );
                  
                  return needsMatch || sizeMatch;
                });
                
                return {
                  primary_products: recommendedProducts.slice(0, 3),
                  solution_overview: generateSolutionOverview(opportunity, recommendedProducts),
                  key_benefits: extractKeyBenefits(recommendedProducts, opportunity),
                  roi_projection: calculateROIProjection(opportunity, recommendedProducts)
                };
              }
              
              function calculatePricing(opportunity, account, products) {
                const basePricing = products.reduce((total, product) => total + product.base_price, 0);
                
                // Apply discounts based on various factors
                let discount = 0;
                
                // Volume discount
                if (opportunity.amount > 100000) discount += 0.15;
                else if (opportunity.amount > 50000) discount += 0.10;
                else if (opportunity.amount > 25000) discount += 0.05;
                
                // Company size discount
                if (account.employee_count > 1000) discount += 0.10;
                
                // Industry discount
                if (['nonprofit', 'education'].includes(account.industry?.toLowerCase())) {
                  discount += 0.15;
                }
                
                // Cap discount at 25%
                discount = Math.min(discount, 0.25);
                
                const finalPrice = basePricing * (1 - discount);
                
                return {
                  base_price: basePricing,
                  discount_percentage: Math.round(discount * 100),
                  discount_amount: basePricing - finalPrice,
                  final_price: finalPrice,
                  payment_terms: determinePaymentTerms(account, finalPrice),
                  pricing_valid_until: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString()
                };
              }
              
              function generateImplementationPlan(opportunity, account) {
                const companySize = account.employee_count || 0;
                let timelineWeeks = 8; // Default
                
                if (companySize > 1000) timelineWeeks = 16;
                else if (companySize > 500) timelineWeeks = 12;
                else if (companySize > 100) timelineWeeks = 10;
                
                return {
                  estimated_timeline: \`\${timelineWeeks} weeks\`,
                  phases: [
                    { name: 'Discovery & Planning', duration: '2 weeks', description: 'Requirements gathering and solution architecture' },
                    { name: 'System Configuration', duration: '4 weeks', description: 'Platform setup and customization' },
                    { name: 'Testing & Training', duration: '2 weeks', description: 'User acceptance testing and team training' },
                    { name: 'Go-Live & Support', duration: '1 week', description: 'Production deployment and initial support' }
                  ],
                  success_metrics: [
                    'User adoption rate > 80% within 30 days',
                    'Process efficiency improvement > 40%',
                    'User satisfaction score > 4.5/5.0'
                  ]
                };
              }
              
              function categorizeCompanySize(employeeCount) {
                if (!employeeCount) return 'unknown';
                if (employeeCount >= 1000) return 'enterprise';
                if (employeeCount >= 200) return 'mid-market';
                if (employeeCount >= 50) return 'smb';
                return 'small';
              }
              
              // Execute proposal generation
              const proposalResult = generateProposal(opportunity, account, contact, products || []);
              return { ...opportunity, proposal: proposalResult };
            `
          }
        }
      },
