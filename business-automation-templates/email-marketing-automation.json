  "workflow": {
    "blocks": {
      "trigger_handler": {
        "id": "trigger_001",
        "type": "starter",
        "position": { "x": 100, "y": 200 },
        "data": {
          "title": "Email Campaign Trigger",
          "description": "Handle various trigger events for email automation"
        },
        "subBlocks": {
          "triggerTypes": {
            "type": "multi-select",
            "value": [
              "new_subscriber",
              "purchase_completed",
              "cart_abandoned",
              "website_behavior",
              "date_based",
              "manual_trigger"
            ]
          }
        }
      },
      "subscriber_segmentation": {
        "id": "segment_001",
        "type": "function",
        "position": { "x": 300, "y": 200 },
        "data": {
          "title": "Dynamic Subscriber Segmentation",
          "description": "Intelligently segment subscribers based on behavior, demographics, and engagement"
        },
        "subBlocks": {
          "code": {
            "type": "javascript", 
            "value": `
              /**
               * Advanced Subscriber Segmentation Engine
               * Creates dynamic segments based on multiple criteria
               * @param {Object} subscriber - Subscriber data
               * @param {Object} trigger - Trigger event data
               * @returns {Object} - Segmented subscriber with campaign targeting
               */
              function segmentSubscriber(subscriber, trigger) {
                const segments = {
                  // Engagement-based segments
                  engagement: {
                    'highly_engaged': {
                      criteria: {
                        email_opens_30d: { min: 10 },
                        click_rate: { min: 0.05 },
                        last_engagement: { max_days_ago: 14 }
                      },
                      priority: 'high',
                      send_time: 'optimal'
                    },
                    'moderately_engaged': {
                      criteria: {
                        email_opens_30d: { min: 3, max: 9 },
                        click_rate: { min: 0.02, max: 0.05 },
                        last_engagement: { max_days_ago: 30 }
                      },
                      priority: 'medium',
                      send_time: 'standard'
                    },
                    'low_engaged': {
                      criteria: {
                        email_opens_30d: { max: 2 },
                        click_rate: { max: 0.02 },
                        last_engagement: { min_days_ago: 30 }
                      },
                      priority: 'low',
                      send_time: 'reengagement'
                    }
                  },
                  
                  // Behavioral segments
                  behavior: {
                    'frequent_buyer': {
                      criteria: {
                        purchases_90d: { min: 3 },
                        avg_order_value: { min: 100 }
                      },
                      campaign_type: 'vip_content'
                    },
                    'first_time_buyer': {
                      criteria: {
                        total_purchases: { equals: 1 },
                        days_since_purchase: { max: 30 }
                      },
                      campaign_type: 'onboarding'
                    },
                    'cart_abandoner': {
                      criteria: {
                        abandoned_carts_30d: { min: 1 },
                        cart_value: { min: 50 }
                      },
                      campaign_type: 'recovery'
                    },
                    'browser': {
                      criteria: {
                        website_visits_30d: { min: 5 },
                        purchases_90d: { equals: 0 }
                      },
                      campaign_type: 'conversion'
                    }
                  },
                  
                  // Demographic segments
                  demographic: {
                    'enterprise': {
                      criteria: {
                        company_size: ['1000+', '500-1000'],
                        job_title: ['ceo', 'cto', 'vp', 'director']
                      },
                      content_type: 'enterprise'
                    },
                    'smb': {
                      criteria: {
                        company_size: ['1-50', '51-200'],
                        job_title: ['founder', 'owner', 'manager']
                      },
                      content_type: 'smb_focused'
                    },
                    'individual': {
                      criteria: {
                        account_type: 'personal'
                      },
                      content_type: 'consumer'
                    }
                  }
                };
                
                // Function to evaluate criteria
                function meetsCriteria(data, criteria) {
                  return Object.entries(criteria).every(([key, condition]) => {
                    const value = data[key];
                    if (!value) return false;
                    
                    if (condition.min !== undefined && value < condition.min) return false;
                    if (condition.max !== undefined && value > condition.max) return false;
                    if (condition.equals !== undefined && value !== condition.equals) return false;
                    if (condition.includes && !condition.includes.includes(value)) return false;
                    if (Array.isArray(condition) && !condition.includes(value)) return false;
                    
                    // Date-based conditions
                    if (condition.max_days_ago !== undefined) {
                      const daysSince = Math.floor((Date.now() - new Date(value)) / (1000 * 60 * 60 * 24));
                      return daysSince <= condition.max_days_ago;
                    }
                    if (condition.min_days_ago !== undefined) {
                      const daysSince = Math.floor((Date.now() - new Date(value)) / (1000 * 60 * 60 * 24));
                      return daysSince >= condition.min_days_ago;
                    }
                    
                    return true;
                  });
                }
                
                // Determine segments
                const matchedSegments = {};
                
                // Check engagement segments
                for (const [segmentName, segmentData] of Object.entries(segments.engagement)) {
                  if (meetsCriteria(subscriber, segmentData.criteria)) {
                    matchedSegments.engagement = segmentName;
                    matchedSegments.engagement_data = segmentData;
                    break;
                  }
                }
                
                // Check behavioral segments
                for (const [segmentName, segmentData] of Object.entries(segments.behavior)) {
                  if (meetsCriteria(subscriber, segmentData.criteria)) {
                    matchedSegments.behavior = segmentName;
                    matchedSegments.behavior_data = segmentData;
                    break;
                  }
                }
                
                // Check demographic segments
                for (const [segmentName, segmentData] of Object.entries(segments.demographic)) {
                  if (meetsCriteria(subscriber, segmentData.criteria)) {
                    matchedSegments.demographic = segmentName;
                    matchedSegments.demographic_data = segmentData;
                    break;
                  }
                }
                
                // Determine optimal send time based on engagement
                const optimalSendTime = subscriber.timezone 
                  ? calculateOptimalSendTime(subscriber.timezone, matchedSegments.engagement)
                  : '09:00';
                
                return {
                  ...subscriber,
                  segments: matchedSegments,
                  campaign_priority: matchedSegments.engagement_data?.priority || 'medium',
                  optimal_send_time: optimalSendTime,
                  content_personalization: determinePersonalization(matchedSegments),
                  segmented_at: new Date().toISOString()
                };
              }
              
              // Helper function for send time optimization
              function calculateOptimalSendTime(timezone, engagementLevel) {
                const timeMap = {
                  'highly_engaged': '09:00',
                  'moderately_engaged': '10:30', 
                  'low_engaged': '14:00'
                };
                return timeMap[engagementLevel] || '09:00';
              }
              
              // Helper function for personalization
              function determinePersonalization(segments) {
                const personalization = {
                  tone: 'professional',
                  content_focus: 'general',
                  cta_style: 'standard'
                };
                
                if (segments.demographic === 'enterprise') {
                  personalization.tone = 'executive';
                  personalization.content_focus = 'roi_focused';
                  personalization.cta_style = 'business';
                } else if (segments.demographic === 'individual') {
                  personalization.tone = 'friendly';
                  personalization.content_focus = 'benefit_focused';
                  personalization.cta_style = 'casual';
                }
                
                return personalization;
              }
              
              // Execute segmentation
              const segmentedSubscriber = segmentSubscriber(subscriber, trigger);
              return segmentedSubscriber;
            `
          }
        }
      },
      "campaign_router": {
        "id": "router_001", 
