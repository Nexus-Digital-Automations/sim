      "behavioral_email": {
        "id": "behavior_001",
        "type": "function",
        "position": { "x": 700, "y": 400 },
        "data": {
          "title": "Behavioral Email Generator",
          "description": "Generate personalized emails based on website behavior and interactions"
        },
        "subBlocks": {
          "code": {
            "type": "javascript",
            "value": `
              /**
               * Behavioral Email Content Generator
               * Creates personalized email content based on user behavior
               */
              function generateBehavioralEmail(subscriber, behaviorData) {
                const emailTemplates = {
                  'product_page_visit': {
                    subject: "Interested in ${product.name}? Here's what others love about it",
                    content_blocks: [
                      'product_spotlight',
                      'customer_reviews', 
                      'related_products',
                      'limited_time_offer'
                    ]
                  },
                  'content_download': {
                    subject: "Thanks for downloading ${content.title}",
                    content_blocks: [
                      'thank_you_message',
                      'related_content',
                      'next_steps',
                      'expert_consultation'
                    ]
                  },
                  'pricing_page_visit': {
                    subject: "Questions about our pricing? Let's chat",
                    content_blocks: [
                      'pricing_clarification',
                      'plan_comparison',
                      'customer_success_story',
                      'demo_booking'
                    ]
                  },
                  'support_page_visit': {
                    subject: "Need help? We're here for you",
                    content_blocks: [
                      'help_offer',
                      'popular_resources',
                      'contact_options',
                      'community_link'
                    ]
                  },
                  'blog_engagement': {
                    subject: "More insights on ${blog.topic}",
                    content_blocks: [
                      'related_articles',
                      'expert_insights',
                      'upcoming_webinars',
                      'newsletter_signup'
                    ]
                  }
                };
                
                const behaviorType = behaviorData.type;
                const template = emailTemplates[behaviorType];
                
                if (!template) {
                  return {
                    subject: "Thanks for visiting ${COMPANY_NAME}",
                    content_type: 'generic_follow_up',
                    personalization_level: 'basic'
                  };
                }
                
                // Generate personalized subject line
                const personalizedSubject = template.subject
                  .replace(/\\$\\{subscriber\\.([^}]+)\\}/g, (match, field) => subscriber[field] || '')
                  .replace(/\\$\\{product\\.([^}]+)\\}/g, (match, field) => behaviorData.product?.[field] || '')
                  .replace(/\\$\\{content\\.([^}]+)\\}/g, (match, field) => behaviorData.content?.[field] || '')
                  .replace(/\\$\\{blog\\.([^}]+)\\}/g, (match, field) => behaviorData.blog?.[field] || '');
                
                // Determine send timing based on behavior recency
                const hoursSinceBehavior = (Date.now() - new Date(behaviorData.timestamp)) / (1000 * 60 * 60);
                let sendDelay = 'immediate';
                
                if (hoursSinceBehavior < 2) sendDelay = '2_hours';
                else if (hoursSinceBehavior < 24) sendDelay = '24_hours';
                else sendDelay = 'immediate';
                
                return {
                  subject: personalizedSubject,
                  content_blocks: template.content_blocks,
                  send_delay: sendDelay,
                  behavior_context: behaviorData,
                  personalization_level: 'high',
                  tracking_tags: [behaviorType, 'behavioral_email'],
                  generated_at: new Date().toISOString()
                };
              }
              
              const emailContent = generateBehavioralEmail(subscriber, trigger.behavior_data);
              return {
                ...subscriber,
                email_content: emailContent,
                campaign_type: 'behavioral'
              };
            `
          }
        }
      },
