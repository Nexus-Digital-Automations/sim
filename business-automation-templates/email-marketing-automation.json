      "engagement_tracker": {
        "id": "engage_001",
        "type": "function",
        "position": { "x": 1300, "y": 250 },
        "data": {
          "title": "Engagement Score Update",
          "description": "Update subscriber engagement scores based on email interactions"
        },
        "subBlocks": {
          "code": {
            "type": "javascript",
            "value": `
              /**
               * Update subscriber engagement score based on email performance
               */
              function updateEngagementScore(subscriber, emailMetrics) {
                const currentScore = subscriber.engagement_score || 50; // Default neutral score
                let scoreAdjustment = 0;
                
                // Positive engagement signals
                if (emailMetrics.opened) scoreAdjustment += 5;
                if (emailMetrics.clicked) scoreAdjustment += 10;
                if (emailMetrics.replied) scoreAdjustment += 15;
                if (emailMetrics.forwarded) scoreAdjustment += 8;
                if (emailMetrics.converted) scoreAdjustment += 20;
                
                // Negative engagement signals
                if (emailMetrics.bounced) scoreAdjustment -= 10;
                if (emailMetrics.spam_reported) scoreAdjustment -= 25;
                if (emailMetrics.unsubscribed) scoreAdjustment -= 30;
                
                // Time-based engagement (quick engagement is more valuable)
                if (emailMetrics.opened && emailMetrics.time_to_open < 3600) { // Opened within 1 hour
                  scoreAdjustment += 3;
                }
                
                const newScore = Math.max(0, Math.min(100, currentScore + scoreAdjustment));
                
                // Update engagement tier
                let engagementTier = 'low_engaged';
                if (newScore >= 70) engagementTier = 'highly_engaged';
                else if (newScore >= 40) engagementTier = 'moderately_engaged';
                
                return {
                  ...subscriber,
                  engagement_score: newScore,
                  engagement_tier: engagementTier,
                  last_engagement_update: new Date().toISOString(),
                  engagement_history: [
                    ...(subscriber.engagement_history || []).slice(-19), // Keep last 20 records
                    {
                      timestamp: new Date().toISOString(),
                      score_change: scoreAdjustment,
                      new_score: newScore,
                      campaign_id: emailMetrics.campaign_id,
                      actions: Object.keys(emailMetrics).filter(key => emailMetrics[key] === true)
                    }
                  ]
                };
              }
              
              // This would typically be called by a webhook when engagement data is received
              const updatedSubscriber = updateEngagementScore(subscriber, {
                opened: true,
                time_to_open: 1800, // 30 minutes
                campaign_id: campaign_id
              });
              
              return updatedSubscriber;
            `
          }
        }
      }
    },
