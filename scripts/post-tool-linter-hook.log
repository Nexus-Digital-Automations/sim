          "+// ========================",
          "+// KNOWLEDGE BASE & RAG SYSTEM",
          "+// ========================",
          "+",
          "+/**",
          "+ * Knowledge Base table - RAG-enabled document collections",
          "+ * ",
          "+ * Central registry for document collections supporting:",
          "+ * - Vector similarity search with embeddings",
          "+ * - Flexible document tagging and organization",
          "+ * - Configurable chunking strategies",
          "+ * - Usage tracking and billing integration",
          "+ * - Workspace-based access control",
          "+ * ",
          "+ * RAG ARCHITECTURE:",
          "+ * - Documents are chunked into embeddings for retrieval",
          "+ * - Vector similarity search finds relevant content",
          "+ * - Full-text search provides keyword matching",
          "+ * - Tag-based filtering enables targeted search",
          "+ * ",
          "+ * EMBEDDING STRATEGY:",
          "+ * - text-embedding-3-small: Cost-effective, 1536 dimensions",
          "+ * - HNSW indexes for fast similarity search",
          "+ * - Configurable chunking for optimal retrieval",
          "+ * - Incremental updates with deduplication",
          "+ * ",
          "+ * PERFORMANCE FEATURES:",
          "+ * - Token counting for usage billing",
          "+ * - Soft delete for data retention",
          "+ * - Workspace isolation for security",
          "+ * - Optimized indexes for common queries",
          "+ */",
          " export const knowledgeBase = pgTable(",
          "   'knowledge_base',",
          "   {",
          "-    id: text('id').primaryKey(),",
          "+    id: text('id').primaryKey(), // Knowledge base identifier",
          "     userId: text('user_id')",
          "       .notNull()",
          "-      .references(() => user.id, { onDelete: 'cascade' }),",
          "-    workspaceId: text('workspace_id').references(() => workspace.id),",
          "-    name: text('name').notNull(),",
          "-    description: text('description'),",
          "+      .references(() => user.id, { onDelete: 'cascade' }), // Owner for access control",
          "+    workspaceId: text('workspace_id').references(() => workspace.id), // Team workspace (optional)",
          "+    name: text('name').notNull(), // User-defined collection name",
          "+    description: text('description'), // Purpose and content description",
          " ",
          "-    // Token tracking for usage",
          "-    tokenCount: integer('token_count').notNull().default(0),",
          "+    // Usage tracking for billing and analytics",
          "+    tokenCount: integer('token_count').notNull().default(0), // Total tokens for cost calculation",
          " ",
          "-    // Embedding configuration",
          "-    embeddingModel: text('embedding_model').notNull().default('text-embedding-3-small'),",
          "-    embeddingDimension: integer('embedding_dimension').notNull().default(1536),",
          "+    // Vector embedding configuration",
          "+    embeddingModel: text('embedding_model').notNull().default('text-embedding-3-small'), // OpenAI model",
          "+    embeddingDimension: integer('embedding_dimension').notNull().default(1536), // Vector dimensions",
          " ",
          "-    // Chunking configuration stored as JSON for flexibility",
          "+    // Document chunking strategy (JSON for future extensibility)",
          "     chunkingConfig: json('chunking_config')",
          "       .notNull()",
          "-      .default('{\"maxSize\": 1024, \"minSize\": 1, \"overlap\": 200}'),",
          "+      .default('{\"maxSize\": 1024, \"minSize\": 1, \"overlap\": 200}'), // Chunking parameters",
          " ",
          "-    // Soft delete support",
          "-    deletedAt: timestamp('deleted_at'),",
          "+    // Soft delete support for data retention",
          "+    deletedAt: timestamp('deleted_at'), // Null = active, timestamp = deleted",
          " ",
          "-    // Metadata and timestamps",
          "+    // Audit and lifecycle timestamps",
          "     createdAt: timestamp('created_at').notNull().defaultNow(),",
          "     updatedAt: timestamp('updated_at').notNull().defaultNow(),",
          "   },",
          "   (table) => ({",
          "-    // Primary access patterns",
          "+    // Index for user's knowledge bases",
          "     userIdIdx: index('kb_user_id_idx').on(table.userId),",
          "+    // Index for workspace knowledge bases",
          "     workspaceIdIdx: index('kb_workspace_id_idx').on(table.workspaceId),",
          "-    // Composite index for user's workspaces",
          "+    // Composite index for user workspace queries",
          "     userWorkspaceIdx: index('kb_user_workspace_idx').on(table.userId, table.workspaceId),",
          "     // Index for soft delete filtering",
          "     deletedAtIdx: index('kb_deleted_at_idx').on(table.deletedAt),",
          "   })",
          " )",
          " ",
          "+/**",
          "+ * Documents table - Individual files within knowledge bases",
          "+ * ",
          "+ * Manages uploaded documents and their processing pipeline:",
          "+ * - File metadata and storage references",
          "+ * - Processing status tracking for async workflows",
          "+ * - Content statistics for analytics and billing",
          "+ * - Tag-based organization and filtering",
          "+ * - Enable/disable controls for search inclusion",
          "+ * ",
          "+ * DOCUMENT PROCESSING PIPELINE:",
          "+ * 1. Upload: File stored, metadata recorded (pending)",
          "+ * 2. Processing: Content extraction, chunking (processing)",
          "+ * 3. Embedding: Vector generation for chunks (processing)",
          "+ * 4. Indexing: Search index creation (completed)",
          "+ * 5. Error Handling: Failure recovery (failed)",
          "+ * ",
          "+ * SUPPORTED FILE TYPES:",
          "+ * - PDF documents: Text extraction with layout preservation",
          "+ * - Text files: Plain text processing",
          "+ * - Word documents: Content extraction",
          "+ * - PowerPoint: Slide content processing",
          "+ * - Excel: Table and data extraction",
          "+ * ",
          "+ * TAG SYSTEM:",
          "+ * - 7 tag slots for flexible categorization",
          "+ * - Tags inherited by all document chunks",
          "+ * - Fast filtering without JOIN operations",
          "+ * - Custom tag definitions per knowledge base",
          "+ */",
          " export const document = pgTable(",
          "   'document',",
          "   {",
          "-    id: text('id').primaryKey(),",
          "+    id: text('id').primaryKey(), // Document identifier",
          "     knowledgeBaseId: text('knowledge_base_id')",
          "       .notNull()",
          "-      .references(() => knowledgeBase.id, { onDelete: 'cascade' }),",
          "+      .references(() => knowledgeBase.id, { onDelete: 'cascade' }), // Parent knowledge base",
          " ",
          "-    // File information",
          "-    filename: text('filename').notNull(),",
          "-    fileUrl: text('file_url').notNull(),",
          "-    fileSize: integer('file_size').notNull(), // Size in bytes",
          "-    mimeType: text('mime_type').notNull(), // e.g., 'application/pdf', 'text/plain'",
          "+    // File metadata and storage",
          "+    filename: text('filename').notNull(), // Original filename for display",
          "+    fileUrl: text('file_url').notNull(), // Storage URL (S3, etc.)",
          "+    fileSize: integer('file_size').notNull(), // File size in bytes",
          "+    mimeType: text('mime_type').notNull(), // MIME type for processing strategy",
          " ",
          "-    // Content statistics",
          "-    chunkCount: integer('chunk_count').notNull().default(0),",
          "-    tokenCount: integer('token_count').notNull().default(0),",
          "-    characterCount: integer('character_count').notNull().default(0),",
          "+    // Content analysis results",
          "+    chunkCount: integer('chunk_count').notNull().default(0), // Number of generated chunks",
          "+    tokenCount: integer('token_count').notNull().default(0), // Total tokens for billing",
          "+    characterCount: integer('character_count').notNull().default(0), // Character count",
          " ",
          "-    // Processing status",
          "-    processingStatus: text('processing_status').notNull().default('pending'), // 'pending', 'processing', 'completed', 'failed'",
