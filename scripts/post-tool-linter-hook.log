        "new_string": "/**\n * Documents table - Individual files within knowledge bases\n * \n * Manages uploaded documents and their processing pipeline:\n * - File metadata and storage references\n * - Processing status tracking for async workflows\n * - Content statistics for analytics and billing\n * - Tag-based organization and filtering\n * - Enable/disable controls for search inclusion\n * \n * DOCUMENT PROCESSING PIPELINE:\n * 1. Upload: File stored, metadata recorded (pending)\n * 2. Processing: Content extraction, chunking (processing)\n * 3. Embedding: Vector generation for chunks (processing)\n * 4. Indexing: Search index creation (completed)\n * 5. Error Handling: Failure recovery (failed)\n * \n * SUPPORTED FILE TYPES:\n * - PDF documents: Text extraction with layout preservation\n * - Text files: Plain text processing\n * - Word documents: Content extraction\n * - PowerPoint: Slide content processing\n * - Excel: Table and data extraction\n * \n * TAG SYSTEM:\n * - 7 tag slots for flexible categorization\n * - Tags inherited by all document chunks\n * - Fast filtering without JOIN operations\n * - Custom tag definitions per knowledge base\n */\nexport const document = pgTable(\n  'document',\n  {\n    id: text('id').primaryKey(), // Document identifier\n    knowledgeBaseId: text('knowledge_base_id')\n      .notNull()\n      .references(() => knowledgeBase.id, { onDelete: 'cascade' }), // Parent knowledge base\n\n    // File metadata and storage\n    filename: text('filename').notNull(), // Original filename for display\n    fileUrl: text('file_url').notNull(), // Storage URL (S3, etc.)\n    fileSize: integer('file_size').notNull(), // File size in bytes\n    mimeType: text('mime_type').notNull(), // MIME type for processing strategy\n\n    // Content analysis results\n    chunkCount: integer('chunk_count').notNull().default(0), // Number of generated chunks\n    tokenCount: integer('token_count').notNull().default(0), // Total tokens for billing\n    characterCount: integer('character_count').notNull().default(0), // Character count\n\n    // Async processing workflow status\n    processingStatus: text('processing_status').notNull().default('pending'), // Workflow state\n    processingStartedAt: timestamp('processing_started_at'), // Processing start time\n    processingCompletedAt: timestamp('processing_completed_at'), // Completion time\n    processingError: text('processing_error'), // Error message if failed\n\n    // Document availability controls\n    enabled: boolean('enabled').notNull().default(true), // Include in search results\n    deletedAt: timestamp('deleted_at'), // Soft delete timestamp\n\n    // Tag-based categorization system (inherited by chunks)\n    tag1: text('tag1'), // Configurable tag slot 1\n    tag2: text('tag2'), // Configurable tag slot 2\n    tag3: text('tag3'), // Configurable tag slot 3\n    tag4: text('tag4'), // Configurable tag slot 4\n    tag5: text('tag5'), // Configurable tag slot 5\n    tag6: text('tag6'), // Configurable tag slot 6\n    tag7: text('tag7'), // Configurable tag slot 7\n\n    // Document lifecycle timestamp\n    uploadedAt: timestamp('uploaded_at').notNull().defaultNow(),\n  },\n  (table) => ({\n    // Primary index for knowledge base document listing\n    knowledgeBaseIdIdx: index('doc_kb_id_idx').on(table.knowledgeBaseId),\n    // Index for filename search and autocomplete\n    filenameIdx: index('doc_filename_idx').on(table.filename),\n    // Composite index for chronological document listing\n    kbUploadedAtIdx: index('doc_kb_uploaded_at_idx').on(table.knowledgeBaseId, table.uploadedAt),\n    // Index for processing status monitoring\n    processingStatusIdx: index('doc_processing_status_idx').on(\n      table.knowledgeBaseId,\n      table.processingStatus\n    ),\n    // Individual tag indexes for fast filtering\n    tag1Idx: index('doc_tag1_idx').on(table.tag1),\n    tag2Idx: index('doc_tag2_idx').on(table.tag2),\n    tag3Idx: index('doc_tag3_idx').on(table.tag3),\n    tag4Idx: index('doc_tag4_idx').on(table.tag4),\n    tag5Idx: index('doc_tag5_idx').on(table.tag5),\n    tag6Idx: index('doc_tag6_idx').on(table.tag6),\n    tag7Idx: index('doc_tag7_idx').on(table.tag7),\n  })\n)"
